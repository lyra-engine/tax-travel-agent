---
interface Props {
  i: string;
  title: string;
  body: string;
  href: string;
  cta: string;
  span?: string;
}
const { i, title, body, href, cta, span = "" } = Astro.props;
---

<a
  href={href}
  data-parallax
  class={`reveal p-rise group relative flex flex-col justify-between rounded-2xl border border-white/10 bg-white/[0.02] p-7 transition-[background,border-color] hover:border-white/30 hover:bg-white/[0.04] ${span}`}
>
  <div>
    <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-500">
      {i}
    </span>
    <h3
      class="mt-5 font-display text-2xl font-light tracking-tight text-white"
      data-split="subtle"
    >
      {title}
    </h3>
    <p class="mt-3 max-w-md text-sm leading-relaxed text-ink-300">{body}</p>
  </div>
  <div class="mt-8 flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.25em] text-ink-400 transition group-hover:text-white">
    {cta}
    <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
  </div>
</a>
