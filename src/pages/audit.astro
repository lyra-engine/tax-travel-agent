---
import Layout from "../layouts/Layout.astro";
import { readAudit, summarize } from "../lib/advisor/audit";
import PageHero from "../components/ui/PageHero.astro";
import PageMap from "../components/ui/PageMap.astro";
import ScrollScripts from "../components/ui/ScrollScripts.astro";

export const prerender = false;

const url = new URL(Astro.request.url);
const clientFilter = url.searchParams.get("client") ?? undefined;
const limitParam = Number(url.searchParams.get("limit") ?? "100");
const limit = Number.isFinite(limitParam) ? Math.min(500, Math.max(10, limitParam)) : 100;

const all = await readAudit(500);
const activeOrgId = Astro.locals.org?.id;
const scoped = activeOrgId
  ? all.filter((e) => !e.orgId || e.orgId === activeOrgId)
  : all;
const filtered = clientFilter
  ? scoped.filter((e) => e.clientName?.toLowerCase() === clientFilter.toLowerCase())
  : scoped;
const entries = filtered.slice(0, limit);
const stats = summarize(filtered);

function fmtMs(ms: number) {
  if (ms < 1000) return `${ms}ms`;
  return `${(ms / 1000).toFixed(1)}s`;
}
function fmtDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleString(undefined, {
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}

const sections = [
  { id: "ch-summary",  label: "Summary" },
  { id: "ch-ledger",   label: "Ledger" },
  { id: "ch-filter",   label: "Filter" },
];
---

<Layout title="Audit log — Fidelis">
  <PageMap sections={sections} />

  <PageHero
    kicker="Compliance · Ledger"
    code="05"
    title="Every turn,"
    accent="on the record."
    lede="The agent is a fiduciary tool. Every prompt, every token, every tool call, every dollar — written to disk, sortable, exportable. Nothing happens off-book."
    eyebrow="Audit"
  />

  <!-- ============================================================== -->
  <!-- Summary                                                           -->
  <!-- ============================================================== -->
  <section id="ch-summary" class="mx-auto max-w-7xl px-6 pt-16 pb-10">
    <div class="section-reveal">
      <p class="chapter-mark"><em>01</em> Summary</p>
      <h2
        class="mt-6 font-display text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-tight tracking-tight text-white"
        data-split-words
      >
        The running tally, at a glance.
      </h2>
      <p
        class="mt-4 max-w-2xl text-ink-400"
        data-split-words="body"
      >
        Cumulative metrics across all scoped entries. Anchored in
        <code class="font-mono text-xs text-ink-300">data/audit.log.jsonl</code>.
      </p>
    </div>

    <div class="section-reveal mt-10 grid gap-0 border-y border-white/5 sm:grid-cols-2 lg:grid-cols-5">
      {
        [
          { label: "Turns", value: stats.turns.toLocaleString(), tone: "ink" },
          { label: "Total tokens", value: stats.totalTokens.toLocaleString(), tone: "ink" },
          {
            label: "Input / Output",
            value: `${stats.inputTokens.toLocaleString()} / ${stats.outputTokens.toLocaleString()}`,
            tone: "ink",
          },
          { label: "Tool calls", value: stats.toolCallCount.toLocaleString(), tone: "ink" },
          {
            label: "Total cost",
            value: `$${stats.totalCostUsd.toFixed(4)}`,
            tone: "brand",
          },
        ].map((card, i) => (
          <div
            class={`relative py-8 ${i !== 0 ? "lg:border-l border-white/5" : ""} px-6`}
          >
            <div class="label-xs">{card.label}</div>
            <div
              class={
                card.tone === "brand"
                  ? "mt-3 font-display text-[clamp(1.75rem,3.2vw,2.75rem)] font-light tabular-nums text-brand-300"
                  : "mt-3 font-display text-[clamp(1.75rem,3.2vw,2.75rem)] font-light tabular-nums text-white"
              }
              data-num
            >
              {card.value}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <div class="mx-auto my-6 max-w-7xl px-6">
    <div class="hairline-x opacity-50"></div>
  </div>

  <!-- ============================================================== -->
  <!-- Filter                                                            -->
  <!-- ============================================================== -->
  <section id="ch-filter" class="mx-auto max-w-7xl px-6 pt-8 pb-8">
    <div class="section-reveal">
      <p class="chapter-mark"><em>02</em> Filter</p>
      <h2
        class="mt-6 font-display text-[clamp(1.5rem,2.4vw,2rem)] font-light leading-tight tracking-tight text-white"
        data-split-words
      >
        Narrow the ledger.
      </h2>
    </div>
    <form class="section-reveal mt-8 flex flex-wrap items-end gap-6" method="get">
      <label class="flex flex-col gap-2">
        <span class="label-xs">Client name filter</span>
        <input
          name="client"
          value={clientFilter ?? ""}
          placeholder="Alex Nakamura"
          class="field w-72"
        />
      </label>
      <label class="flex flex-col gap-2">
        <span class="label-xs">Limit</span>
        <input
          name="limit"
          type="number"
          value={limit}
          min="10"
          max="500"
          class="field w-28"
          data-num
        />
      </label>
      <button class="btn-primary">Apply</button>
      <a href="/audit" class="btn-link">Clear</a>
    </form>
  </section>

  <div class="mx-auto my-6 max-w-7xl px-6">
    <div class="hairline-x opacity-50"></div>
  </div>

  <!-- ============================================================== -->
  <!-- Ledger                                                            -->
  <!-- ============================================================== -->
  <section id="ch-ledger" class="mx-auto max-w-7xl px-6 pt-8 pb-28">
    <div class="section-reveal">
      <p class="chapter-mark"><em>03</em> Ledger</p>
      <h2
        class="mt-6 font-display text-[clamp(1.5rem,2.4vw,2rem)] font-light leading-tight tracking-tight text-white"
        data-split-words
      >
        One row per agent turn.
      </h2>
      <p class="mt-3 text-sm text-ink-400">
        Showing the most recent <span class="font-mono text-ink-300">{entries.length}</span> of <span class="font-mono text-ink-300">{filtered.length}</span> entries.
      </p>
    </div>

    <div class="section-reveal mt-10 border border-white/[0.06] bg-black/20">
      {entries.length === 0 ? (
        <div class="px-6 py-20 text-center">
          <p class="kicker">no entries</p>
          <p class="mt-4 font-display text-xl font-light italic text-ink-200">
            The ledger is quiet.
          </p>
          <p class="mt-2 text-sm text-ink-400">
            Send a message on <a href="/agent" class="btn-link">the agent</a> and return.
          </p>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="border-b border-white/5 text-left">
              <tr>
                <th class="label-xs px-4 py-4 font-normal">When</th>
                <th class="label-xs px-4 py-4 font-normal">User</th>
                <th class="label-xs px-4 py-4 font-normal">Client</th>
                <th class="label-xs px-4 py-4 font-normal">Prompt</th>
                <th class="label-xs px-4 py-4 font-normal">Model</th>
                <th class="label-xs px-4 py-4 text-right font-normal">In</th>
                <th class="label-xs px-4 py-4 text-right font-normal">Out</th>
                <th class="label-xs px-4 py-4 font-normal">Tools</th>
                <th class="label-xs px-4 py-4 text-right font-normal">Time</th>
                <th class="label-xs px-4 py-4 text-right font-normal">Cost</th>
                <th class="label-xs px-4 py-4 font-normal">Status</th>
              </tr>
            </thead>
            <tbody>
              {entries.map((e) => (
                <tr class="border-b border-white/5 last:border-0 transition hover:bg-white/[0.02]">
                  <td class="whitespace-nowrap px-4 py-4 font-mono text-[11px] text-ink-400">
                    {fmtDate(e.ts)}
                  </td>
                  <td class="whitespace-nowrap px-4 py-4 text-xs text-ink-300">
                    {e.userEmail ?? <span class="text-ink-500">—</span>}
                  </td>
                  <td class="whitespace-nowrap px-4 py-4 font-display text-[15px] font-light text-white">
                    {e.clientName ?? <span class="text-ink-500">—</span>}
                  </td>
                  <td class="max-w-xs truncate px-4 py-4 text-ink-200" title={e.userMessage}>
                    {e.userMessage}
                  </td>
                  <td class="whitespace-nowrap px-4 py-4 font-mono text-[11px] text-ink-400">
                    {e.model}
                  </td>
                  <td class="whitespace-nowrap px-4 py-4 text-right font-mono text-[11px] text-ink-300" data-num>
                    {e.inputTokens.toLocaleString()}
                  </td>
                  <td class="whitespace-nowrap px-4 py-4 text-right font-mono text-[11px] text-ink-300" data-num>
                    {e.outputTokens.toLocaleString()}
                  </td>
                  <td class="px-4 py-4 text-xs">
                    <div class="flex flex-wrap gap-1">
                      {e.toolCalls.length === 0 ? (
                        <span class="text-ink-500">—</span>
                      ) : (
                        e.toolCalls.map((t) => (
                          <span
                            class={`tag ${t.error ? "tag-danger" : ""}`}
                            title={`${t.durationMs}ms${t.error ? " — " + t.error : ""}`}
                          >
                            {t.name}
                          </span>
                        ))
                      )}
                    </div>
                  </td>
                  <td class="whitespace-nowrap px-4 py-4 text-right font-mono text-[11px] text-ink-400" data-num>
                    {fmtMs(e.durationMs)}
                  </td>
                  <td class="whitespace-nowrap px-4 py-4 text-right font-mono text-[11px] text-brand-300" data-num>
                    ${e.estCostUsd.toFixed(5)}
                  </td>
                  <td class="whitespace-nowrap px-4 py-4 text-xs">
                    {e.error ? (
                      <span class="tag tag-danger">error</span>
                    ) : e.finishReason === "stop" ? (
                      <span class="tag tag-accent">ok</span>
                    ) : (
                      <span class="tag tag-warn">{e.finishReason}</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </section>

  <ScrollScripts />
</Layout>
