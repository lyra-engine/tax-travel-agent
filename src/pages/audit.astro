---
import Layout from "../layouts/Layout.astro";
import { readAudit, summarize } from "../lib/advisor/audit";

export const prerender = false;

const url = new URL(Astro.request.url);
const clientFilter = url.searchParams.get("client") ?? undefined;
const limitParam = Number(url.searchParams.get("limit") ?? "100");
const limit = Number.isFinite(limitParam) ? Math.min(500, Math.max(10, limitParam)) : 100;

const all = await readAudit(500);
const activeOrgId = Astro.locals.org?.id;
const scoped = activeOrgId
  ? all.filter((e) => !e.orgId || e.orgId === activeOrgId)
  : all;
const filtered = clientFilter
  ? scoped.filter((e) => e.clientName?.toLowerCase() === clientFilter.toLowerCase())
  : scoped;
const entries = filtered.slice(0, limit);
const stats = summarize(filtered);

function fmtMs(ms: number) {
  if (ms < 1000) return `${ms}ms`;
  return `${(ms / 1000).toFixed(1)}s`;
}
function fmtDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleString(undefined, {
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}
---

<Layout title="Audit log — Fidelis">
  <section class="mx-auto max-w-7xl px-6 pt-10 pb-20">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <span class="chip w-fit">
          <span class="h-1.5 w-1.5 rounded-full bg-warn-500"></span>
          Compliance
        </span>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Audit log
        </h1>
        <p class="mt-2 max-w-2xl text-ink-300">
          Every agent turn is logged server-side to
          <code class="rounded bg-white/5 px-1 font-mono text-xs">data/audit.log.jsonl</code>.
          Use this for cost tracking, compliance review, and debugging.
        </p>
      </div>
      <form class="flex flex-wrap items-end gap-2" method="get">
        <label class="flex flex-col gap-1 text-xs text-ink-400">
          Client name filter
          <input
            name="client"
            value={clientFilter ?? ""}
            placeholder="Alex Nakamura"
            class="rounded-lg border border-white/10 bg-ink-900/60 px-3 py-1.5 text-sm text-white outline-none focus:border-brand-500"
          />
        </label>
        <label class="flex flex-col gap-1 text-xs text-ink-400">
          Limit
          <input
            name="limit"
            type="number"
            value={limit}
            min="10"
            max="500"
            class="w-24 rounded-lg border border-white/10 bg-ink-900/60 px-3 py-1.5 text-sm text-white outline-none focus:border-brand-500"
          />
        </label>
        <button class="rounded-lg bg-brand-500 px-4 py-1.5 text-sm font-medium text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400">
          Apply
        </button>
        <a href="/audit" class="text-xs text-ink-400 hover:text-white">Clear</a>
      </form>
    </div>

    <!-- summary cards -->
    <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
      {
        [
          { label: "Turns", value: stats.turns.toLocaleString(), tone: "ink" },
          { label: "Total tokens", value: stats.totalTokens.toLocaleString(), tone: "ink" },
          {
            label: "Input / Output",
            value: `${stats.inputTokens.toLocaleString()} / ${stats.outputTokens.toLocaleString()}`,
            tone: "ink",
          },
          { label: "Tool calls", value: stats.toolCallCount.toLocaleString(), tone: "ink" },
          {
            label: "Total cost (USD)",
            value: `$${stats.totalCostUsd.toFixed(4)}`,
            tone: "brand",
          },
        ].map((card) => (
          <div class="card p-4">
            <p class="text-xs uppercase tracking-wider text-ink-500">{card.label}</p>
            <p
              class={
                card.tone === "brand"
                  ? "mt-1 text-2xl font-semibold tabular-nums text-brand-300"
                  : "mt-1 text-2xl font-semibold tabular-nums text-white"
              }
            >
              {card.value}
            </p>
          </div>
        ))
      }
    </div>

    <!-- table -->
    <div class="card mt-8 overflow-hidden p-0">
      {entries.length === 0 ? (
        <div class="px-6 py-12 text-center text-sm text-ink-400">
          No audit entries yet. Send a message on{" "}
          <a href="/agent" class="text-brand-300 hover:underline">/agent</a> and
          come back.
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="border-b border-white/5 bg-white/[0.02] text-left text-xs uppercase tracking-wider text-ink-500">
              <tr>
                <th class="px-4 py-3 font-medium">When</th>
                <th class="px-4 py-3 font-medium">User</th>
                <th class="px-4 py-3 font-medium">Client</th>
                <th class="px-4 py-3 font-medium">Prompt</th>
                <th class="px-4 py-3 font-medium">Model</th>
                <th class="px-4 py-3 font-medium text-right">In</th>
                <th class="px-4 py-3 font-medium text-right">Out</th>
                <th class="px-4 py-3 font-medium">Tools</th>
                <th class="px-4 py-3 font-medium text-right">Time</th>
                <th class="px-4 py-3 font-medium text-right">Cost</th>
                <th class="px-4 py-3 font-medium">Status</th>
              </tr>
            </thead>
            <tbody>
              {entries.map((e) => (
                <tr class="border-b border-white/5 last:border-0 hover:bg-white/[0.02]">
                  <td class="whitespace-nowrap px-4 py-3 text-xs text-ink-400">
                    {fmtDate(e.ts)}
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 text-xs text-ink-300">
                    {e.userEmail ?? <span class="text-ink-500">—</span>}
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 text-ink-100">
                    {e.clientName ?? <span class="text-ink-500">—</span>}
                  </td>
                  <td class="max-w-xs truncate px-4 py-3 text-ink-200" title={e.userMessage}>
                    {e.userMessage}
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 text-xs font-mono text-ink-400">
                    {e.model}
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 text-right font-mono text-xs text-ink-300">
                    {e.inputTokens.toLocaleString()}
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 text-right font-mono text-xs text-ink-300">
                    {e.outputTokens.toLocaleString()}
                  </td>
                  <td class="px-4 py-3 text-xs">
                    <div class="flex flex-wrap gap-1">
                      {e.toolCalls.length === 0 ? (
                        <span class="text-ink-500">—</span>
                      ) : (
                        e.toolCalls.map((t) => (
                          <span
                            class={`rounded-full border px-1.5 py-0.5 font-mono text-[10px] ${
                              t.error
                                ? "border-danger-500/30 bg-danger-500/10 text-danger-400"
                                : "border-white/10 bg-white/[0.03] text-ink-300"
                            }`}
                            title={`${t.durationMs}ms${t.error ? " — " + t.error : ""}`}
                          >
                            {t.name}
                          </span>
                        ))
                      )}
                    </div>
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 text-right font-mono text-xs text-ink-400">
                    {fmtMs(e.durationMs)}
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 text-right font-mono text-xs text-brand-300">
                    ${e.estCostUsd.toFixed(5)}
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 text-xs">
                    {e.error ? (
                      <span class="rounded-full bg-danger-500/15 px-2 py-0.5 text-danger-400">
                        error
                      </span>
                    ) : e.finishReason === "stop" ? (
                      <span class="rounded-full bg-accent-500/15 px-2 py-0.5 text-accent-400">
                        ok
                      </span>
                    ) : (
                      <span class="rounded-full bg-warn-500/15 px-2 py-0.5 text-warn-400">
                        {e.finishReason}
                      </span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </section>
</Layout>
