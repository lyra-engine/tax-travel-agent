---
import Layout from "../layouts/Layout.astro";
import Scenarios from "../components/scenarios/Scenarios.tsx";
import PageHero from "../components/ui/PageHero.astro";
import PageMap from "../components/ui/PageMap.astro";
import ScrollScripts from "../components/ui/ScrollScripts.astro";

export const prerender = true;

const sections = [
  { id: "ch-overview",   label: "Premise" },
  { id: "ch-compare",    label: "Compare" },
  { id: "ch-delta",      label: "Delta" },
  { id: "ch-handoff",    label: "Hand-off" },
];
---

<Layout title="Scenarios — Fidelis">
  <PageMap sections={sections} />

  <PageHero
    kicker="What-if planning"
    code="02"
    title="Two futures,"
    accent="one deterministic compare."
    lede="Side-by-side runs of the same tools the agent uses. Drive the inputs, watch the delta, drop the result straight into a chat turn or a PDF memo."
    eyebrow="Scenarios"
  />

  <!-- ============================================================== -->
  <!-- Premise                                                           -->
  <!-- ============================================================== -->
  <section id="ch-overview" class="mx-auto max-w-7xl px-6 pt-16 pb-8">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr]">
      <div class="section-reveal">
        <p class="chapter-mark"><em>01</em> Premise</p>
        <h2
          class="mt-6 font-display text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-tight tracking-tight text-white"
          data-split-words
        >
          Planning is a question, not a spreadsheet.
        </h2>
        <p
          class="mt-5 max-w-xl text-base leading-relaxed text-ink-300"
          data-split-words="body"
        >
          Every advisor conversation starts with a what-if: what if they retire
          a year earlier, what if we convert in 2026, what if the client moves
          states mid-year. Scenarios lets you stage the answer before you
          speak it.
        </p>
      </div>
      <aside class="section-reveal space-y-4 border-l border-white/5 pl-6 text-sm text-ink-300 md:pl-10">
        <div>
          <span class="label-xs">Same engine as the agent</span>
          <p class="mt-2 text-ink-400">
            All numbers come from the exact TypeScript tools the agent calls.
            No hidden model math. No re-implementation.
          </p>
        </div>
        <div>
          <span class="label-xs">Deterministic &amp; auditable</span>
          <p class="mt-2 text-ink-400">
            Inputs → tools → outputs. Every figure can be retraced. Hand the
            result back to the agent as a chat turn for memo generation.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <div class="mx-auto my-6 max-w-7xl px-6">
    <div class="hairline-x opacity-50"></div>
  </div>

  <!-- ============================================================== -->
  <!-- Compare                                                           -->
  <!-- ============================================================== -->
  <section id="ch-compare" class="relative mx-auto max-w-7xl px-6 pt-6 pb-12">
    <div class="section-reveal">
      <p class="chapter-mark"><em>02</em> Compare</p>
      <h2
        class="mt-6 font-display text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-tight tracking-tight text-white"
        data-split-words
      >
        Two columns. One truth.
      </h2>
      <p
        class="mt-4 max-w-xl text-ink-400"
        data-split-words="body"
      >
        Drop a baseline on the left, the alternative on the right. Run the same
        tools against both.
      </p>
    </div>

    <div class="section-reveal mt-12">
      <Scenarios client:only="react" />
    </div>
  </section>

  <div class="mx-auto my-10 max-w-7xl px-6">
    <div class="hairline-x opacity-50"></div>
  </div>

  <!-- ============================================================== -->
  <!-- Delta                                                             -->
  <!-- ============================================================== -->
  <section id="ch-delta" class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-10 md:grid-cols-3">
      <div class="section-reveal md:col-span-1">
        <p class="chapter-mark"><em>03</em> Delta</p>
        <h2
          class="mt-6 font-display text-[clamp(1.5rem,2.8vw,2.25rem)] font-light leading-tight tracking-tight text-white"
          data-split-words
        >
          The number that decides.
        </h2>
      </div>
      <div class="section-reveal md:col-span-2 space-y-6 text-ink-300">
        <p data-split-words="body">
          A scenario compare isn't useful until you can see the single number
          the advisor will quote. Fidelis surfaces the delta — federal,
          state, effective rate, and cash-on-hand — stripped of ceremony.
        </p>
        <ul class="space-y-3 text-sm text-ink-400">
          <li class="hairline-row flex items-start justify-between gap-4 py-3">
            <span class="label-xs">Federal</span>
            <span class="font-mono text-ink-300">signed USD delta</span>
          </li>
          <li class="hairline-row flex items-start justify-between gap-4 py-3">
            <span class="label-xs">State</span>
            <span class="font-mono text-ink-300">per state · top bracket flag</span>
          </li>
          <li class="hairline-row flex items-start justify-between gap-4 py-3">
            <span class="label-xs">Effective rate</span>
            <span class="font-mono text-ink-300">Δ bps · direction arrow</span>
          </li>
          <li class="hairline-row flex items-start justify-between gap-4 py-3">
            <span class="label-xs">Cash in hand</span>
            <span class="font-mono text-ink-300">after-tax, annualized</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <div class="mx-auto my-10 max-w-7xl px-6">
    <div class="hairline-x opacity-50"></div>
  </div>

  <!-- ============================================================== -->
  <!-- Hand-off                                                          -->
  <!-- ============================================================== -->
  <section id="ch-handoff" class="mx-auto max-w-7xl px-6 pb-28 pt-10">
    <div class="grid gap-10 md:grid-cols-[1fr_1fr]">
      <div class="section-reveal">
        <p class="chapter-mark"><em>04</em> Hand-off</p>
        <h2
          class="mt-6 font-display text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-tight tracking-tight text-white"
          data-split-words
        >
          From compare to conversation.
        </h2>
        <p
          class="mt-5 max-w-lg text-ink-300"
          data-split-words="body"
        >
          Every run can be injected into the agent as a chat turn, or exported
          as a PDF memo. The client sees one document. You see the full trace.
        </p>
      </div>
      <div class="section-reveal flex flex-col gap-3">
        <a href="/agent" class="hairline-row flex items-center justify-between gap-4 px-0 py-4">
          <div>
            <div class="label-xs">01</div>
            <div class="mt-1 font-display text-xl font-light text-white">Open the agent</div>
            <div class="mt-1 text-sm text-ink-400">Continue the conversation with the scenario pinned.</div>
          </div>
          <span class="font-mono text-ink-400 transition group-hover:text-white">→</span>
        </a>
        <a href="/intake" class="hairline-row flex items-center justify-between gap-4 px-0 py-4">
          <div>
            <div class="label-xs">02</div>
            <div class="mt-1 font-display text-xl font-light text-white">Import a 1040</div>
            <div class="mt-1 text-sm text-ink-400">Extract baseline numbers from the client's return.</div>
          </div>
          <span class="font-mono text-ink-400">→</span>
        </a>
        <a href="/tracker" class="hairline-row flex items-center justify-between gap-4 px-0 py-4">
          <div>
            <div class="label-xs">03</div>
            <div class="mt-1 font-display text-xl font-light text-white">Residency tracker</div>
            <div class="mt-1 text-sm text-ink-400">Confirm days + substantial-presence exposure.</div>
          </div>
          <span class="font-mono text-ink-400">→</span>
        </a>
      </div>
    </div>
  </section>

  <ScrollScripts />
</Layout>
