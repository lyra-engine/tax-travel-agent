---
import Layout from "../layouts/Layout.astro";
import Scenarios from "../components/scenarios/Scenarios.tsx";

export const prerender = true;
---

<Layout title="Scenarios — Fidelis">
  <section class="mx-auto max-w-7xl px-6 pt-10 pb-20">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <span class="chip w-fit">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
          What-if planning
        </span>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Compare scenarios
        </h1>
        <p class="mt-2 max-w-3xl text-ink-300">
          Side-by-side comparisons running the same deterministic tools the AI
          agent uses. Drive the inputs, see the delta, then bring the result
          into a chat turn or PDF memo.
        </p>
      </div>
    </div>

    <div class="mt-8">
      <Scenarios client:only="react" />
    </div>
  </section>
</Layout>
