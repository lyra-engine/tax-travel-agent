---
import Layout from "../layouts/Layout.astro";
import { authEnabled } from "../lib/auth/auth";

export const prerender = false;

const enabled = authEnabled();
const next = new URL(Astro.request.url).searchParams.get("next") ?? "/agent";
---

<Layout title="Sign in — Fidelis">
  <section class="mx-auto flex max-w-md flex-col px-6 pt-12 pb-20">
    <div class="card p-6">
      <span class="chip w-fit">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
        Sign in
      </span>
      <h1 class="mt-3 text-2xl font-semibold text-white">Welcome back</h1>
      <p class="mt-1 text-sm text-ink-400">
        Sign in to your Fidelis workspace.
      </p>

      {!enabled && (
        <div class="mt-5 rounded-lg border border-accent-500/30 bg-accent-500/10 px-3 py-2 text-xs text-accent-200">
          Auth is currently <b>disabled</b>. The agent is open to anyone who
          hits the server. Set{" "}
          <code class="rounded bg-black/30 px-1 font-mono">FIDELIS_AUTH=1</code>{" "}
          in <code class="rounded bg-black/30 px-1 font-mono">.env</code> to
          enforce login across the app.
        </div>
      )}

      <form method="post" action="/api/auth/login" class="mt-6 space-y-4">
        <input type="hidden" name="next" value={next} />
        <label class="block">
          <span class="text-xs font-medium uppercase tracking-wider text-ink-400">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="mt-1 w-full rounded-lg border border-white/10 bg-ink-900/60 px-3 py-2 text-sm text-white outline-none focus:border-brand-500"
          />
        </label>
        <label class="block">
          <span class="text-xs font-medium uppercase tracking-wider text-ink-400">Password</span>
          <input
            type="password"
            name="password"
            required
            autocomplete="current-password"
            class="mt-1 w-full rounded-lg border border-white/10 bg-ink-900/60 px-3 py-2 text-sm text-white outline-none focus:border-brand-500"
          />
        </label>
        <button class="w-full rounded-lg bg-brand-500 px-4 py-2 text-sm font-medium text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400">
          Sign in
        </button>
      </form>

      <p class="mt-4 text-center text-xs text-ink-400">
        No account?{" "}
        <a href={`/signup?next=${encodeURIComponent(next)}`} class="text-brand-300 hover:underline">
          Create one
        </a>
      </p>
    </div>
  </section>
</Layout>
