---
import Layout from "../layouts/Layout.astro";
import DocumentIntake from "../components/intake/DocumentIntake.tsx";

export const prerender = false;

const hasKey = Boolean(
  import.meta.env.OPENAI_API_KEY || import.meta.env.GROQ_API_KEY,
);
---

<Layout title="Document intake — Fidelis">
  <section class="mx-auto max-w-7xl px-6 pt-10 pb-20">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <span class="chip w-fit">
          <span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>
          Intake
        </span>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Document intake
        </h1>
        <p class="mt-2 max-w-3xl text-ink-300">
          Upload a W-2, 1099, or 1040 page. Fidelis uses OpenAI vision to
          extract the fields, then lets you cherry-pick what to merge into a
          client profile. Nothing is stored server-side — the image is sent to
          the model, the structured extraction is returned, and the merge
          happens in your browser.
        </p>
      </div>
      {!hasKey && (
        <div class="max-w-sm rounded-xl border border-warn-500/40 bg-warn-500/10 px-4 py-3 text-sm text-warn-200">
          <p class="font-medium text-warn-300">OPENAI_API_KEY not set</p>
          <p class="mt-1 text-xs text-warn-200/80">
            Vision extraction requires an OpenAI key. Set{" "}
            <code class="rounded bg-black/30 px-1 font-mono text-xs">OPENAI_API_KEY</code>{" "}
            in <code class="rounded bg-black/30 px-1 font-mono text-xs">.env</code>{" "}
            and restart the dev server.
          </p>
        </div>
      )}
    </div>

    <div class="mt-8">
      <DocumentIntake client:only="react" />
    </div>
  </section>
</Layout>
