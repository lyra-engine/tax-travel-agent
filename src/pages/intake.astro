---
import Layout from "../layouts/Layout.astro";
import DocumentIntake from "../components/intake/DocumentIntake.tsx";
import PageHero from "../components/ui/PageHero.astro";
import PageMap from "../components/ui/PageMap.astro";
import ScrollScripts from "../components/ui/ScrollScripts.astro";

export const prerender = false;

const hasKey = Boolean(
  import.meta.env.OPENAI_API_KEY || import.meta.env.GROQ_API_KEY,
);

const sections = [
  { id: "ch-premise", label: "Premise" },
  { id: "ch-upload",  label: "Upload" },
  { id: "ch-merge",   label: "Merge" },
  { id: "ch-trust",   label: "Trust" },
];
---

<Layout title="Document intake — Fidelis">
  <PageMap sections={sections} />

  <PageHero
    kicker="Vision · OCR"
    code="03"
    title="Paper in,"
    accent="structured data out."
    lede="Drop a W-2, 1099, or 1040 page. Fidelis reads the form with vision, returns typed fields, and lets you cherry-pick which values to merge into a client profile."
    eyebrow="Intake"
  />

  {!hasKey && (
    <div class="mx-auto max-w-7xl px-6 pt-6">
      <div class="section-reveal flex items-start gap-3 border-l-2 border-warn-500/60 bg-warn-500/5 px-5 py-4">
        <span class="label-xs text-warn-300">vision key missing</span>
        <p class="text-sm text-warn-100/80">
          Vision extraction requires an OpenAI key. Set
          <code class="font-mono text-xs text-warn-200">OPENAI_API_KEY</code>
          in <code class="font-mono text-xs text-warn-200">.env</code> and restart.
          Groq models will not perform vision extraction.
        </p>
      </div>
    </div>
  )}

  <!-- ============================================================== -->
  <!-- Premise                                                           -->
  <!-- ============================================================== -->
  <section id="ch-premise" class="mx-auto max-w-7xl px-6 pt-16 pb-8">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr]">
      <div class="section-reveal">
        <p class="chapter-mark"><em>01</em> Premise</p>
        <h2
          class="mt-6 font-display text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-tight tracking-tight text-white"
          data-split-words
        >
          Client onboarding shouldn't start with typing.
        </h2>
        <p
          class="mt-5 max-w-xl text-base leading-relaxed text-ink-300"
          data-split-words="body"
        >
          Every new prospect arrives with paperwork. Fidelis turns the top
          page of a 1040 — or a stack of 1099s — into structured fields in
          under a minute. You review, you approve, you move on.
        </p>
      </div>
      <aside class="section-reveal space-y-4 border-l border-white/5 pl-6 text-sm text-ink-300 md:pl-10">
        <div>
          <span class="label-xs">Nothing stored</span>
          <p class="mt-2 text-ink-400">
            The image is sent to the vision model. The structured extraction
            is returned. Nothing persists server-side — the merge happens in
            your browser.
          </p>
        </div>
        <div>
          <span class="label-xs">Human in the loop</span>
          <p class="mt-2 text-ink-400">
            You always see the raw extraction, field by field, before it
            touches a profile. Reject what's wrong, keep what's right.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <div class="mx-auto my-6 max-w-7xl px-6">
    <div class="hairline-x opacity-50"></div>
  </div>

  <!-- ============================================================== -->
  <!-- Upload                                                            -->
  <!-- ============================================================== -->
  <section id="ch-upload" class="mx-auto max-w-7xl px-6 pt-6 pb-12">
    <div class="section-reveal">
      <p class="chapter-mark"><em>02</em> Upload</p>
      <h2
        class="mt-6 font-display text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-tight tracking-tight text-white"
        data-split-words
      >
        Drop the file. Read what Fidelis sees.
      </h2>
      <p
        class="mt-4 max-w-2xl text-ink-400"
        data-split-words="body"
      >
        Supported: W-2, 1099-INT, 1099-DIV, 1099-NEC, 1040 page 1. JPG, PNG,
        or PDF page exports.
      </p>
    </div>

    <div class="section-reveal mt-10">
      <DocumentIntake client:only="react" />
    </div>
  </section>

  <div class="mx-auto my-10 max-w-7xl px-6">
    <div class="hairline-x opacity-50"></div>
  </div>

  <!-- ============================================================== -->
  <!-- Merge                                                             -->
  <!-- ============================================================== -->
  <section id="ch-merge" class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-10 md:grid-cols-3">
      <div class="section-reveal md:col-span-1">
        <p class="chapter-mark"><em>03</em> Merge</p>
        <h2
          class="mt-6 font-display text-[clamp(1.5rem,2.8vw,2.25rem)] font-light leading-tight tracking-tight text-white"
          data-split-words
        >
          Three clicks to a client profile.
        </h2>
      </div>
      <div class="section-reveal md:col-span-2 space-y-0">
        <div class="hairline-row flex items-start justify-between gap-4 py-4">
          <div>
            <div class="label-xs">01 · Review</div>
            <div class="mt-1 text-sm text-ink-300">Every extracted field appears alongside its source snippet.</div>
          </div>
          <span class="font-mono text-xs text-ink-500">visual diff</span>
        </div>
        <div class="hairline-row flex items-start justify-between gap-4 py-4">
          <div>
            <div class="label-xs">02 · Pick</div>
            <div class="mt-1 text-sm text-ink-300">Toggle which fields to merge. Skip anything you can't verify.</div>
          </div>
          <span class="font-mono text-xs text-ink-500">per-field</span>
        </div>
        <div class="hairline-row flex items-start justify-between gap-4 py-4">
          <div>
            <div class="label-xs">03 · Merge</div>
            <div class="mt-1 text-sm text-ink-300">New fields land on the client profile. Conflicts prompt for resolution.</div>
          </div>
          <span class="font-mono text-xs text-ink-500">local storage</span>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto my-10 max-w-7xl px-6">
    <div class="hairline-x opacity-50"></div>
  </div>

  <!-- ============================================================== -->
  <!-- Trust                                                             -->
  <!-- ============================================================== -->
  <section id="ch-trust" class="mx-auto max-w-7xl px-6 pb-28 pt-10">
    <div class="grid gap-10 md:grid-cols-[1fr_1fr]">
      <div class="section-reveal">
        <p class="chapter-mark"><em>04</em> Trust</p>
        <h2
          class="mt-6 font-display text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-tight tracking-tight text-white"
          data-split-words
        >
          Vision is fast. You are the signoff.
        </h2>
        <p
          class="mt-5 max-w-lg text-ink-300"
          data-split-words="body"
        >
          Every extraction is logged to the audit trail with the model, token
          count, and cost. Wrong field? Overwrite in place — the profile is a
          live document.
        </p>
      </div>
      <div class="section-reveal flex flex-col gap-3">
        <a href="/agent" class="hairline-row flex items-center justify-between gap-4 px-0 py-4">
          <div>
            <div class="label-xs">01</div>
            <div class="mt-1 font-display text-xl font-light text-white">Ask the agent</div>
            <div class="mt-1 text-sm text-ink-400">Start a conversation with the freshly-imported profile.</div>
          </div>
          <span class="font-mono text-ink-400">→</span>
        </a>
        <a href="/audit" class="hairline-row flex items-center justify-between gap-4 px-0 py-4">
          <div>
            <div class="label-xs">02</div>
            <div class="mt-1 font-display text-xl font-light text-white">Review the trail</div>
            <div class="mt-1 text-sm text-ink-400">Every extraction, every token, every dollar.</div>
          </div>
          <span class="font-mono text-ink-400">→</span>
        </a>
      </div>
    </div>
  </section>

  <ScrollScripts />
</Layout>
