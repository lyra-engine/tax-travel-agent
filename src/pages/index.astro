---
export const prerender = true;
import "../styles/global.css";
import MiniFact from "../components/landing/MiniFact.astro";
import BigStat from "../components/landing/BigStat.astro";
import Capability from "../components/landing/Capability.astro";
import ToolRow from "../components/landing/ToolRow.astro";
import FlowCaption from "../components/landing/FlowCaption.astro";
---

<!doctype html>
<html lang="en" class="h-full">
	<head>
		<meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fidelis — Tax AI for the advisor's chair</title>
    <meta
      name="description"
      content="An opinionated tax AI built for financial advisors. Grounded answers, tool-verified calculations, audit-ready by design."
    />
    <meta name="color-scheme" content="dark" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap"
    />
	</head>
  <body class="relative min-h-full overflow-x-hidden antialiased font-light" data-page="landing">
    <!-- Progress rail -->
    <div class="progress-rail" id="progress-rail"><i id="progress-bar"></i></div>

    <!-- Bottom-left scroll HUD — kept clear of right rail via CSS max-width + rail sits in upper band -->
    <div class="depth-hud" aria-hidden="true">
      <div class="depth-hud-panel">
        <div class="dial shrink-0"><span id="hud-pct">00</span></div>
        <div class="depth-hud-copy min-w-0">
          <span class="depth-hud-ch"
            >CH · <span id="hud-ch">00</span> / 05</span
          >
          <span class="depth-hud-sub">SCROLL DEPTH</span>
          <span class="depth-hud-hint hidden sm:block">↑↓ NAVIGATE · / → AGENT</span>
        </div>
      </div>
    </div>

    <!-- Scroll-linked background stack + chapter watermarks + progress sheen -->
    <div class="landing-scroll-bg" aria-hidden="true">
      <div class="scroll-bg-sheet scroll-bg-sheet--bloom"></div>
      <div class="scroll-bg-sheet scroll-bg-sheet--cool"></div>
      <div class="scroll-bg-sheet scroll-bg-sheet--gold"></div>
      <div class="scroll-bg-grid"></div>
      <!-- Premium niche motif: marginal bracket + ledger grid + tool nodes (always-on motion, scroll parallax) -->
      <div class="scroll-bg-ledger-wrap">
        <svg
          class="fidelis-ledger-scene"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 800 800"
          preserveAspectRatio="xMidYMid slice"
        >
          <defs>
            <linearGradient id="flGold" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#6a5340" stop-opacity="0.35"></stop>
              <stop offset="40%" stop-color="#b8926a" stop-opacity="0.9"></stop>
              <stop offset="100%" stop-color="#c9a882" stop-opacity="0.4"></stop>
            </linearGradient>
            <linearGradient id="flLyra" x1="0%" y1="100%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#4a6eb8" stop-opacity="0.2"></stop>
              <stop offset="100%" stop-color="#7b9bd4" stop-opacity="0.65"></stop>
            </linearGradient>
            <pattern id="ledgerGridPat" width="48" height="48" patternUnits="userSpaceOnUse">
              <path
                d="M 48 0 L 0 0 0 48"
                fill="none"
                stroke="#4a6eb8"
                stroke-opacity="0.14"
                stroke-width="0.55"></path>
            </pattern>
            <filter id="flGlow" x="-25%" y="-25%" width="150%" height="150%">
              <feGaussianBlur stdDeviation="1.6" result="b"></feGaussianBlur>
              <feMerge>
                <feMergeNode in="b"></feMergeNode>
                <feMergeNode in="SourceGraphic"></feMergeNode>
              </feMerge>
            </filter>
          </defs>
          <g class="ledger-root">
            <rect
              x="56"
              y="96"
              width="688"
              height="608"
              fill="url(#ledgerGridPat)"
              opacity="0.35"
              class="ledger-grid-rect"></rect>
            <path
              class="ledger-baseline"
              d="M 72 628 H 728"
              fill="none"
              stroke="url(#flLyra)"
              stroke-width="0.7"
              stroke-opacity="0.45"
            ></path>
            <g filter="url(#flGlow)">
              <path
                class="ledger-bracket"
                d="M 100 628 L 100 628 L 260 628 L 260 492 L 400 492 L 400 368 L 540 368 L 540 248 L 688 248 L 688 168 L 720 168"
                fill="none"
                stroke="url(#flGold)"
                stroke-width="1.35"
                stroke-linecap="square"
                stroke-linejoin="miter"></path>
              <path
                class="ledger-bracket-ghost"
                d="M 100 628 L 100 628 L 260 628 L 260 492 L 400 492 L 400 368 L 540 368 L 540 248 L 688 248 L 688 168 L 720 168"
                fill="none"
                stroke="url(#flLyra)"
                stroke-width="5"
                stroke-linecap="square"
                stroke-linejoin="miter"
                opacity="0.08"></path>
              <path
                class="ledger-envelope"
                d="M 100 628 C 280 420 520 200 720 168"
                fill="none"
                stroke="url(#flLyra)"
                stroke-width="0.9"
                stroke-linecap="round"></path>
            </g>
            <g class="ledger-nodes">
              <g class="ledger-node" transform="translate(260,628)">
                <circle r="4" fill="#b8926a" opacity="0.85"></circle>
                <circle r="9" fill="none" stroke="#b8926a" stroke-width="0.5" opacity="0.35" class="ledger-node-ring"></circle>
              </g>
              <g class="ledger-node" transform="translate(400,492)">
                <circle r="3.5" fill="#7b9bd4" opacity="0.8"></circle>
                <circle r="8" fill="none" stroke="#4a6eb8" stroke-width="0.45" opacity="0.4" class="ledger-node-ring"></circle>
              </g>
              <g class="ledger-node" transform="translate(540,368)">
                <circle r="3.5" fill="#b8926a" opacity="0.75"></circle>
                <circle r="8" fill="none" stroke="#c9a882" stroke-width="0.45" opacity="0.35" class="ledger-node-ring"></circle>
              </g>
              <g class="ledger-node" transform="translate(688,248)">
                <circle r="3" fill="#7b9bd4" opacity="0.85"></circle>
                <circle r="7" fill="none" stroke="#4a6eb8" stroke-width="0.4" opacity="0.45" class="ledger-node-ring"></circle>
              </g>
            </g>
            <g class="ledger-scan">
              <rect
                class="ledger-scan-bar"
                x="72"
                y="118"
                width="656"
                height="12"
                rx="2"
                fill="#4a6eb8"
                opacity="0.14"></rect>
            </g>
          </g>
        </svg>
      </div>
      <!-- Soft band that travels down the page with scroll depth -->
      <div class="scroll-bg-sheen"></div>
      <!-- Faint viewport frame tightens slightly as you progress -->
      <div class="scroll-bg-frame"></div>
      <div class="scroll-bg-veil"></div>
    </div>


    <!-- Minimal floating top bar -->
    <header class="landing-header fixed inset-x-0 top-0 z-40">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4 text-xs md:gap-8">
        <a href="/" class="group flex shrink-0 items-center gap-3 text-[var(--marea-text)]" aria-label="Fidelis home">
          <span class="grid h-6 w-6 place-items-center rounded-full border border-[color-mix(in_oklab,var(--marea-lyra)_35%,transparent)] bg-[color-mix(in_oklab,var(--marea-mid)_80%,black)] text-[10px] font-bold text-[var(--marea-gold)] shadow-[0_0_24px_var(--marea-gold-glow)]">
            F
          </span>
          <span class="lyra-mark transition group-hover:text-white">
            F<span class="lyra-dot">·</span>I<span class="lyra-dot">·</span>D<span class="lyra-dot">·</span>E<span class="lyra-dot">·</span>L<span class="lyra-dot">·</span>I<span class="lyra-dot">·</span>S
          </span>
        </a>
        <p class="landing-tagline mx-auto hidden text-center md:block lg:mx-0">
          <span class="text-[var(--marea-gold)]">FIDELIS</span> × <span class="text-[var(--marea-lyra)]">LYRA</span>
          <span class="text-[color-mix(in_oklab,var(--marea-text)_35%,transparent)]"> · </span>
          <em>Same rigor. More room.</em>
        </p>
        <nav class="flex shrink-0 items-center gap-6 font-mono text-[10.5px] tracking-[0.22em] text-[color-mix(in_oklab,var(--marea-text)_55%,transparent)]">
          <a href="/agent" class="transition hover:text-[var(--marea-text)]">/agent</a>
          <a href="/scenarios" class="hidden transition hover:text-[var(--marea-text)] sm:inline">/scenarios</a>
          <a href="/intake" class="hidden transition hover:text-[var(--marea-text)] sm:inline">/intake</a>
          <a href="/tracker" class="hidden transition hover:text-[var(--marea-text)] md:inline">/tracker</a>
          <a href="/audit" class="hidden transition hover:text-[var(--marea-text)] md:inline">/audit</a>
        </nav>
      </div>
      <div class="landing-header-hairline" aria-hidden="true"></div>
    </header>

    <!-- Right-edge chapter rail (glass overlay; highlights active chapter while scrolling) -->
    <aside
      class="chapter-rail-overlay pointer-events-none fixed right-4 z-[35] hidden flex-col items-stretch gap-1 sm:right-5 md:flex"
      id="chapter-nav"
      aria-label="Chapter navigation"
    >
      <a href="#ch-00" data-ch="0" class="chapter-rail-link pointer-events-auto is-active" aria-current="location">
        <span class="chapter-rail-num">00</span><span class="chapter-rail-line"></span>
      </a>
      <a href="#ch-01" data-ch="1" class="chapter-rail-link pointer-events-auto">
        <span class="chapter-rail-num">01</span><span class="chapter-rail-line"></span>
      </a>
      <a href="#ch-02" data-ch="2" class="chapter-rail-link pointer-events-auto">
        <span class="chapter-rail-num">02</span><span class="chapter-rail-line"></span>
      </a>
      <a href="#ch-03" data-ch="3" class="chapter-rail-link pointer-events-auto">
        <span class="chapter-rail-num">03</span><span class="chapter-rail-line"></span>
      </a>
      <a href="#ch-04" data-ch="4" class="chapter-rail-link pointer-events-auto">
        <span class="chapter-rail-num">04</span><span class="chapter-rail-line"></span>
      </a>
      <a href="#ch-05" data-ch="5" class="chapter-rail-link pointer-events-auto">
        <span class="chapter-rail-num">05</span><span class="chapter-rail-line"></span>
      </a>
    </aside>

    <!-- ============================================================== -->
    <!-- CHAPTER 00 · HERO — cinematic slam opener                       -->
    <!-- ============================================================== -->
    <section
      id="ch-00"
      class="landing-chapter noise perspective-deep relative flex min-h-[100svh] flex-col justify-between overflow-hidden px-6 pb-10 pt-32 sm:pt-40"
      data-parallax
      data-reveal-host
    >
      <div class="bg-grid parallax-grid-drift absolute inset-0 -z-10"></div>
      <div class="warm-wash"></div>
      <div class="horizon"></div>

      <div class="mx-auto flex w-full max-w-7xl flex-1 flex-col justify-center">
        <!-- Eyebrow: "A tax intelligence" — spaces letters out as it reveals -->
        <div class="flex items-center gap-5">
          <span
            class="anim-eyebrow font-mono text-[11px] uppercase text-earth"
            style="animation-delay: 100ms"
          >
            A tax intelligence
          </span>
          <span class="hairline-anim anim-line w-24" style="animation-delay: 520ms"></span>
          <span
            class="anim-eyebrow font-mono text-[11px] uppercase text-ink-400"
            style="animation-delay: 760ms"
          >
            For the advisor's chair
          </span>
        </div>

        <!-- Slam headline: FIDELIS letters crash in from 3D depth -->
        <h1
          class="mt-10 font-display text-[clamp(3.5rem,12vw,11rem)] font-light leading-[0.88] tracking-[-0.035em] text-white"
          aria-label="Fidelis. A ledger that reasons."
        >
          <span
            class="block anim-glow"
            style="animation-delay: 900ms"
            data-slam
            data-slam-delay="200"
            data-slam-step="85"
          >FIDELIS</span>

          <span
            class="mt-4 block font-display text-[clamp(1.75rem,4.5vw,3.75rem)] leading-[1.05] tracking-[-0.02em] text-ink-200"
          >
            <span
              class="italic-display text-earth"
              data-slide
              data-slide-delay="1300"
              data-slide-step="110"
            >A ledger</span>
            <span
              data-slide
              data-slide-delay="1650"
              data-slide-step="90"
            >that reasons.</span>
          </span>
        </h1>

        <!-- Drawn hairline + body -->
        <div class="mt-12 flex items-start gap-8">
          <span
            class="anim-vline mt-3 block h-14 w-px bg-earth/60"
            style="animation-delay: 2100ms"
          ></span>
          <p
            class="max-w-2xl text-lg leading-relaxed text-[color-mix(in_oklab,var(--marea-text)_72%,transparent)] sm:text-xl"
            data-slide
            data-slide-delay="2300"
            data-slide-step="45"
          >
            An opinionated copilot for licensed financial advisors. Every
            number runs through a deterministic tool. Every claim ties to a
            source. When it doesn't know, it says so — on the record.
          </p>
        </div>

        <blockquote class="editorial-quote reveal reveal-delay-3 mt-14">
          Most of what clients remember isn't the spreadsheet — it's whether the advice had a spine.
          <footer class="editorial-byline">— FIDELIS · ADVISOR CHAIR</footer>
        </blockquote>

        <!-- CTA row with warm gold accent -->
        <div class="reveal reveal-delay-4 mt-14 flex flex-wrap items-center gap-4">
          <a
            href="/agent"
            class="group inline-flex items-center gap-3 bg-earth px-7 py-4 text-sm font-medium tracking-wide text-ink-950 transition hover:bg-earth-soft"
            style="background: var(--color-earth)"
          >
            Open the agent
            <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
          </a>
          <a
            href="#ch-02"
            class="inline-flex items-center gap-3 border border-white/15 px-7 py-4 text-sm text-ink-200 transition hover:border-earth hover:text-white"
          >
            Watch a question answer itself
          </a>
        </div>

        <!-- Chapter-index footer on hero -->
        <div class="reveal reveal-delay-4 mt-24 grid max-w-5xl grid-cols-2 gap-6 sm:grid-cols-4">
          <MiniFact label="Deterministic tools" value="10" />
          <MiniFact label="Source-grounded" value="RAG" suffix="· semantic" />
          <MiniFact label="Every turn logged" value="∞" suffix="· audit-ready" />
          <MiniFact label="Multi-tenant" value="Day 1" />
        </div>
      </div>

      <!-- bottom hero furniture -->
      <div class="mx-auto flex w-full max-w-7xl items-end justify-between pt-10">
        <div class="hidden font-mono text-[10px] tracking-[0.35em] text-ink-500 sm:block">
          <span class="text-earth">00</span> · FIDELIS · TAX INTELLIGENCE
        </div>
        <a
          href="#ch-01"
          class="group flex items-center gap-3 font-mono text-[10px] tracking-[0.35em] text-ink-400 transition hover:text-earth"
        >
          SCROLL TO BEGIN
          <span class="animate-scroll-cue inline-block">↓</span>
        </a>
      </div>
    </section>

    <!-- ============================================================== -->
    <!-- CHAPTER 01 · THE CHAIR — pinned layered chapter (Montana-style) -->
    <!-- ============================================================== -->
    <section
      id="ch-01"
      class="landing-chapter chapter-layer h-200 relative border-t border-white/5"
      data-parallax
    >
      <!-- Pinned background typography: stays fixed while foreground scrolls -->
      <div class="chapter-pin perspective-near" data-reveal-host>
        <!-- Huge held-still backdrop word -->
        <div class="backdrop-type" aria-hidden="true">
          <span data-rise data-rise-delay="100" data-rise-step="55">LEDGER</span>
        </div>

        <!-- Warm wash glow behind foreground -->
        <div class="warm-wash"></div>

        <!-- Foreground composition that fades in over the pinned backdrop -->
        <div class="relative mx-auto w-full max-w-7xl px-6">
          <div class="flex items-center gap-5">
            <span
              class="anim-eyebrow font-mono text-[11px] uppercase text-earth"
              style="animation-delay: 100ms"
            >
              Chapter 01
            </span>
            <span class="hairline-anim anim-line w-24" style="animation-delay: 480ms"></span>
            <span
              class="anim-eyebrow font-mono text-[11px] uppercase text-ink-400"
              style="animation-delay: 720ms"
            >
              The chair
            </span>
          </div>

          <h2
            class="mt-10 font-display text-[clamp(2.25rem,7vw,6rem)] font-light leading-[0.98] tracking-[-0.025em] text-white"
            aria-label="One advisor. One workspace."
          >
            <span
              class="block"
              data-rise
              data-rise-delay="400"
              data-rise-step="32"
            >One advisor.</span>
            <span
              class="mt-2 block italic-display text-earth anim-glow"
              style="animation-delay: 900ms"
              data-rise
              data-rise-delay="700"
              data-rise-step="32"
            >One workspace.</span>
          </h2>

          <span class="anim-line mt-10 block h-px w-32 bg-earth/60" style="animation-delay: 1400ms"></span>

          <div class="mt-12 grid gap-16 lg:grid-cols-[1.1fr,1fr] lg:gap-24">
            <p
              class="max-w-xl text-lg leading-relaxed text-ink-300"
              data-slide
              data-slide-delay="1500"
              data-slide-step="50"
            >
              Most AI tools treat tax like trivia. Fidelis treats it like a
              fiduciary duty — grounded in the active client, answering with
              the firm's assumptions, citing every figure.
            </p>
            <p
              class="max-w-xl self-end text-ink-400"
              data-slide
              data-slide-delay="2000"
              data-slide-step="45"
            >
              Drop it into your advisor platform. Keep the judgment where it
              belongs: with the human.
            </p>
          </div>
        </div>
      </div>

      <!-- Stats block scrolls in below the pinned stage -->
      <div class="relative mx-auto max-w-7xl px-6 pb-32 pt-4" data-reveal-host>
        <span class="anim-line block h-px w-full bg-white/10" style="animation-delay: 100ms"></span>
        <div class="mt-16 grid gap-10 sm:grid-cols-3 sm:gap-4">
          <BigStat value="10" label="Deterministic calculators" caption="Federal, state, AMT, NIIT, QBI, SE, residency, LTCG, Roth ladder, entity comparison." />
          <BigStat value="100%" label="Numbers tool-verified" caption="The agent is prompt-hardened never to compute brackets in prose. All math runs server-side in TypeScript." />
          <BigStat value="0" label="Hallucinated thresholds" caption="Every rate, limit, or threshold resolves through a cite-before-assert gate backed by embeddings." />
        </div>
      </div>
    </section>

    <!-- ============================================================== -->
    <!-- CHAPTER 02 · GROUNDED OR NOTHING  (live chat demo mock)           -->
    <!-- ============================================================== -->
    <section id="ch-02" class="landing-chapter relative overflow-hidden border-t border-white/5 px-6 py-32 sm:py-40" data-parallax>
      <div class="mx-auto max-w-7xl">
        <p class="chapter-marker" data-split="subtle">Chapter 02 · Grounded, or nothing</p>

        <h2
          class="mt-10 max-w-4xl font-display text-[clamp(2.25rem,6vw,5rem)] font-light leading-[1.04] tracking-[-0.02em] text-white"
          data-split
        >
          Every claim must trace to a
          <span class="italic-display">tool</span>
          or a
          <span class="italic-display">citation.</span>
        </h2>

        <p class="reveal reveal-delay-1 mt-8 max-w-2xl text-lg leading-relaxed text-ink-300">
          Watch one question move through the stack. The agent routes to its
          tool registry, cross-checks the knowledge base, and answers only with
          what it can back up.
        </p>

        <!-- Chat transcript -->
        <div
          class="reveal reveal-delay-2 mt-16 overflow-hidden rounded-2xl border border-[color-mix(in_oklab,var(--marea-lyra)_22%,white_8%)] bg-gradient-to-b from-[color-mix(in_oklab,var(--marea-mid)_88%,black)] to-[var(--marea-deep)] shadow-[0_40px_100px_-36px_rgba(91,141,239,0.2),0_28px_80px_-32px_rgba(212,165,116,0.12)]"
        >
          <div class="flex items-center gap-2 border-b border-white/5 bg-white/[0.03] px-5 py-3 font-mono text-xs text-ink-500">
            <span class="h-2.5 w-2.5 rounded-full bg-danger-500/50"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-warn-500/50"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-accent-500/50"></span>
            <span class="ml-3">fidelis · session · client: Alex Nakamura (MFJ, NY)</span>
            <span class="ml-auto animate-breathe text-accent-400">● LIVE</span>
          </div>

          <div class="grid gap-10 px-6 py-10 lg:grid-cols-[1fr,1fr] lg:gap-12 lg:px-10">
            <!-- left: streaming tool calls -->
            <div class="space-y-3">
              <div class="max-w-[92%] self-end rounded-2xl rounded-br-md bg-brand-500/15 px-4 py-3 text-[15px] leading-relaxed text-ink-50 ring-1 ring-brand-500/30 ml-auto">
                If Alex converts $180k of his traditional IRA to Roth this year,
                what's the all-in federal + NY tax hit, and how does it compare
                to a 3-year ladder?
              </div>

              <ToolRow name="get_client_profile" ok ms="4ms" />
              <ToolRow name="federal_tax_estimate" ok ms="1.9ms" note="MFJ · +$180k · brackets 2024" />
              <ToolRow name="state_tax_estimate" ok ms="0.8ms" note="NY · progressive · 8 brackets" />
              <ToolRow name="roth_conversion_ladder" ok ms="2.3ms" note="3 yrs · fill 24% bracket" />
              <ToolRow name="niit_estimate" ok ms="0.4ms" note="MAGI $408k · NII $0" />
              <ToolRow name="search_tax_sources" ok ms="210ms" note="semantic · k=4" />
            </div>

            <!-- right: streamed answer -->
            <div class="relative">
              <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-6 text-[15px] leading-relaxed text-ink-100">
                <p>
                  <b>Short answer:</b> the lump-sum conversion pushes Alex
                  ~<span class="token-chip">$12,400</span> deeper in tax than a
                  3-year ladder that stays inside the 24% bracket.
                </p>
                <ul class="mt-4 space-y-1.5 text-ink-200">
                  <li>— Federal on lump: <b>$61,218</b> incremental, top rate <b>32%</b>.</li>
                  <li>— NY on lump: <b>$13,790</b> at a <b>6.85%</b> marginal.</li>
                  <li>— Ladder blended rate: <b>23.1%</b> across 3 yrs.</li>
                  <li>— NIIT unchanged (no net investment income).</li>
                </ul>
                <div class="mt-5 rounded-lg border border-white/5 bg-black/30 p-4 text-xs">
                  <p class="font-mono uppercase tracking-[0.25em] text-ink-500">Sources</p>
                  <p class="mt-2 text-ink-200">[1] IRS Rev. Proc. 2023-34 · 2024 brackets</p>
                  <p class="mt-1 text-ink-200">[2] NY Dep't of Taxation · IT-201 instructions</p>
                  <p class="mt-1 text-ink-200">[3] §1411 Net Investment Income Tax</p>
                </div>
                <p class="mt-4 text-xs text-ink-500">
                  <span class="animate-caret">▋</span> generating follow-up…
                </p>
              </div>

              <!-- usage chip -->
