---
export const prerender = true;
import "../styles/global.css";
import MiniFact from "../components/landing/MiniFact.astro";
import BigStat from "../components/landing/BigStat.astro";
import Capability from "../components/landing/Capability.astro";
import ToolRow from "../components/landing/ToolRow.astro";
import FlowCaption from "../components/landing/FlowCaption.astro";
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fidelis — Tax AI for the advisor's chair</title>
    <meta
      name="description"
      content="An opinionated tax AI built for financial advisors. Grounded answers, tool-verified calculations, audit-ready by design."
    />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400&family=JetBrains+Mono:wght@300;400;500&display=swap"
    />
  </head>
  <body class="relative min-h-full overflow-x-hidden antialiased" data-page="landing">
    <!-- Progress rail -->
    <div class="progress-rail" id="progress-rail"><i id="progress-bar"></i></div>

    <!-- Floating scroll-depth HUD -->
    <div class="depth-hud" aria-hidden="true">
      <div class="dial"><span id="hud-pct">00</span></div>
      <div class="flex flex-col leading-none">
        <span class="text-ink-300">CH · <span id="hud-ch">00</span> / 05</span>
        <span class="mt-1 text-ink-500">SCROLL DEPTH</span>
      </div>
    </div>

    <!-- Global drifting background layers -->
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <div
        class="orb parallax-drift"
        style="top:-8%;left:-8%;width:40vw;height:40vw;background:radial-gradient(circle,rgba(14,165,233,0.35),transparent 65%)"
      ></div>
      <div
        class="orb parallax-up-slow"
        style="top:28%;right:-12%;width:45vw;height:45vw;background:radial-gradient(circle,rgba(52,211,153,0.22),transparent 65%)"
      ></div>
      <div
        class="orb parallax-y-slow"
        style="bottom:-10%;left:20%;width:55vw;height:55vw;background:radial-gradient(circle,rgba(99,102,241,0.22),transparent 65%)"
      ></div>
    </div>

    <!-- Scroll-driven burn scene: lighter + tax form -->
    <div class="burn-scene" aria-hidden="true">
     <!-- One stage owns the relative geometry so paper + lighter stay fitted -->
     <div class="burn-stage">

      <!-- Warm glow behind the flame -->
      <div class="hot-glow"></div>
      <!-- Warm wash on the paper side near the burn -->
      <div class="paper-lit"></div>

      <!-- The paper (Form 1040 pastiche) -->
      <div class="paper-wrap">
        <svg class="paper-svg" viewBox="0 0 400 520" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <filter id="charEdge" x="-15%" y="-15%" width="130%" height="130%">
              <feTurbulence type="fractalNoise" baseFrequency="0.055" numOctaves="3" seed="7" result="noise" />
              <feDisplacementMap in="SourceGraphic" in2="noise" scale="22" />
            </filter>
            <mask id="paperBurnMask" maskUnits="userSpaceOnUse" x="-40" y="-40" width="480" height="600">
              <rect x="-40" y="-40" width="480" height="600" fill="white" />
              <g filter="url(#charEdge)">
                <ellipse class="burn-shape" cx="400" cy="520" rx="90" ry="90" fill="black" />
              </g>
            </mask>
            <linearGradient id="paperGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#f6ecd3" stop-opacity="0.95" />
              <stop offset="60%" stop-color="#ead9b0" stop-opacity="0.88" />
              <stop offset="100%" stop-color="#d8c28a" stop-opacity="0.82" />
            </linearGradient>
            <linearGradient id="inkBand" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#2a1a10" />
              <stop offset="100%" stop-color="#4a331e" />
            </linearGradient>
          </defs>

          <!-- Masked paper body + form content -->
          <g mask="url(#paperBurnMask)">
            <rect x="0" y="0" width="400" height="520" rx="3" fill="url(#paperGrad)" />

            <!-- Subtle paper fibers -->
            <g opacity="0.12" stroke="#8a6f48" stroke-width="0.5" fill="none">
              <path d="M 0 60 Q 200 56 400 64" />
              <path d="M 0 180 Q 200 176 400 184" />
              <path d="M 0 320 Q 200 316 400 324" />
              <path d="M 0 440 Q 200 436 400 444" />
            </g>

            <!-- Form header -->
            <rect x="24" y="24" width="140" height="12" fill="url(#inkBand)" opacity="0.92" />
            <rect x="24" y="42" width="80" height="4" fill="#6b5a3c" opacity="0.75" />
            <text x="376" y="40" font-family="monospace" font-size="10" fill="#3a2a1a" opacity="0.9" text-anchor="end">2025</text>

            <!-- Divider -->
            <line x1="24" y1="78" x2="376" y2="78" stroke="#6b5a3c" stroke-width="1" opacity="0.6" />

            <!-- Column labels -->
            <text x="24" y="98" font-family="monospace" font-size="8" fill="#5a472d" opacity="0.85" letter-spacing="1">LINE</text>
            <text x="72" y="98" font-family="monospace" font-size="8" fill="#5a472d" opacity="0.85" letter-spacing="1">DESCRIPTION</text>
            <text x="376" y="98" font-family="monospace" font-size="8" fill="#5a472d" opacity="0.85" text-anchor="end" letter-spacing="1">AMOUNT</text>

            <!-- Body rows -->
            <g font-family="monospace" font-size="9" fill="#5a472d" opacity="0.82">
              <!-- Line 1 -->
              <text x="24" y="120">01</text>
              <rect x="72" y="113" width="180" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="120" text-anchor="end">225,000</text>

              <text x="24" y="140">02</text>
              <rect x="72" y="133" width="220" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="140" text-anchor="end">  14,280</text>

              <text x="24" y="160">03</text>
              <rect x="72" y="153" width="160" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="160" text-anchor="end">   8,400</text>

              <text x="24" y="180">04</text>
              <rect x="72" y="173" width="240" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="180" text-anchor="end">  23,500</text>

              <text x="24" y="200">05</text>
              <rect x="72" y="193" width="200" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="200" text-anchor="end"> 247,380</text>

              <text x="24" y="220">06</text>
              <rect x="72" y="213" width="190" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="220" text-anchor="end">  27,700</text>

              <text x="24" y="240">07</text>
              <rect x="72" y="233" width="220" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="240" text-anchor="end"> 219,680</text>

              <text x="24" y="260">08</text>
              <rect x="72" y="253" width="170" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="260" text-anchor="end">  43,937</text>

              <text x="24" y="280">09</text>
              <rect x="72" y="273" width="200" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="280" text-anchor="end">   1,820</text>

              <text x="24" y="300">10</text>
              <rect x="72" y="293" width="230" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="300" text-anchor="end">  45,757</text>
            </g>

            <!-- Section break -->
            <line x1="24" y1="330" x2="376" y2="330" stroke="#6b5a3c" stroke-width="0.6" opacity="0.4" />
            <rect x="24" y="344" width="100" height="8" fill="url(#inkBand)" opacity="0.85" />

            <!-- Sub-rows -->
            <g font-family="monospace" font-size="9" fill="#5a472d" opacity="0.78">
              <text x="24" y="376">11</text>
              <rect x="72" y="369" width="210" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="376" text-anchor="end">   3,520</text>

              <text x="24" y="396">12</text>
              <rect x="72" y="389" width="180" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="396" text-anchor="end">     840</text>

              <text x="24" y="416">13</text>
              <rect x="72" y="409" width="240" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="416" text-anchor="end">   6,200</text>

              <text x="24" y="436">14</text>
              <rect x="72" y="429" width="200" height="1.5" fill="#6b5a3c" opacity="0.5" />
              <text x="376" y="436" text-anchor="end">  10,560</text>
            </g>

            <!-- Footer bar -->
            <line x1="24" y1="460" x2="376" y2="460" stroke="#6b5a3c" stroke-width="1.2" opacity="0.7" />
            <text x="24" y="478" font-family="monospace" font-size="9" fill="#3a2a1a" opacity="0.92">TOTAL TAX</text>
            <text x="376" y="478" font-family="monospace" font-size="10" fill="#3a2a1a" opacity="0.95" text-anchor="end" font-weight="bold">35,197</text>

            <!-- Signature box -->
            <rect x="24" y="492" width="200" height="12" fill="none" stroke="#6b5a3c" stroke-width="0.6" opacity="0.5" />
            <text x="30" y="502" font-family="cursive" font-size="10" fill="#3a2a1a" opacity="0.6" font-style="italic">—</text>
          </g>

          <!-- Charred rim (drawn outside mask, on top of paper) -->
          <g filter="url(#charEdge)" style="mix-blend-mode: multiply;">
            <ellipse class="burn-shape char-ring" cx="400" cy="520" rx="96" ry="96"
                     fill="none" stroke="#1c0d04" stroke-width="10" opacity="0.95" />
          </g>

          <!-- Smoldering edge glow just inside the hole -->
          <g filter="url(#charEdge)">
            <ellipse class="burn-shape char-ring" cx="400" cy="520" rx="88" ry="88"
                     fill="none" stroke="#ff7a1a" stroke-width="4" opacity="0.8" />
          </g>

          <!-- Deep hot-inner glow -->
          <g filter="url(#charEdge)">
            <ellipse class="burn-shape" cx="400" cy="520" rx="76" ry="76"
                     fill="#ff8a2a" opacity="0.28" />
          </g>

          <!-- Brightest hot core -->
          <g filter="url(#charEdge)">
            <ellipse class="burn-shape" cx="400" cy="520" rx="42" ry="42"
                     fill="#ffd48a" opacity="0.35" />
          </g>
        </svg>
      </div>

      <!-- The lighter -->
      <div class="lighter-wrap">
        <svg class="lighter-svg" viewBox="0 0 80 180" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <!-- Brushed gunmetal body: deep blacks at edges, warm steel in middle -->
            <linearGradient id="lighterBody" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%"  stop-color="#0c0608" />
              <stop offset="12%" stop-color="#3a2a28" />
              <stop offset="30%" stop-color="#66554c" />
              <stop offset="55%" stop-color="#8a7a6a" />
              <stop offset="78%" stop-color="#3e2f27" />
              <stop offset="100%" stop-color="#080303" />
            </linearGradient>
            <!-- Subtle vertical fade for depth in body -->
            <linearGradient id="lighterBodyV" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="rgba(255,255,255,0.08)" />
              <stop offset="70%" stop-color="rgba(0,0,0,0)" />
              <stop offset="100%" stop-color="rgba(0,0,0,0.45)" />
            </linearGradient>
            <linearGradient id="lighterCap" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%"  stop-color="#d8d8e0" />
              <stop offset="35%" stop-color="#8a8a92" />
              <stop offset="75%" stop-color="#4e4e58" />
              <stop offset="100%" stop-color="#242430" />
            </linearGradient>
            <linearGradient id="wheelGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%"  stop-color="#b4b4bc" />
              <stop offset="50%" stop-color="#78787e" />
              <stop offset="100%" stop-color="#34343a" />
            </linearGradient>

            <!-- Flame gradients — broader color range, brighter core -->
            <radialGradient id="flameOuter" cx="50%" cy="95%" r="60%">
              <stop offset="0%"   stop-color="#ffffe0" stop-opacity="1" />
              <stop offset="22%"  stop-color="#ffd680" stop-opacity="0.98" />
              <stop offset="55%"  stop-color="#ff8a2a" stop-opacity="0.92" />
              <stop offset="80%"  stop-color="#ff4a00" stop-opacity="0.55" />
              <stop offset="100%" stop-color="#ff2a00" stop-opacity="0" />
            </radialGradient>
            <radialGradient id="flameMid" cx="50%" cy="92%" r="55%">
              <stop offset="0%"   stop-color="#ffffff" stop-opacity="1" />
              <stop offset="45%"  stop-color="#fff1a0" stop-opacity="0.95" />
              <stop offset="85%"  stop-color="#ffb347" stop-opacity="0.2" />
              <stop offset="100%" stop-color="#ffb347" stop-opacity="0" />
            </radialGradient>
            <radialGradient id="flameCore" cx="50%" cy="92%" r="48%">
              <stop offset="0%"   stop-color="#ffffff" stop-opacity="1" />
              <stop offset="70%"  stop-color="#fffbe4" stop-opacity="0.9" />
              <stop offset="100%" stop-color="#fff1a0" stop-opacity="0" />
            </radialGradient>
            <radialGradient id="flameBlue" cx="50%" cy="100%" r="50%">
              <stop offset="0%"   stop-color="#a8dcff" stop-opacity="0.95" />
              <stop offset="60%"  stop-color="#5ea9ff" stop-opacity="0.65" />
              <stop offset="100%" stop-color="#2a7fff" stop-opacity="0" />
            </radialGradient>
          </defs>

          <!-- === Lighter body === -->
          <!-- Drop-shadow underline for body depth -->
          <rect x="19" y="71" width="42" height="98" rx="5"
                fill="#060204" opacity="0.6" />
          <rect x="20" y="72" width="40" height="96" rx="4"
                fill="url(#lighterBody)" stroke="#050203" stroke-width="0.8" />
          <rect x="20" y="72" width="40" height="96" rx="4"
                fill="url(#lighterBodyV)" />
          <!-- Long specular highlight on left side -->
          <rect x="23" y="76" width="1.5" height="88" rx="1"
                fill="#f2dcb6" opacity="0.45" />
          <rect x="25.5" y="76" width="0.6" height="88" rx="0.5"
                fill="#ffffff" opacity="0.18" />
          <!-- Matte brand plate -->
          <rect x="26" y="112" width="28" height="20" rx="1.2"
                fill="#0e0709" opacity="0.6" />
          <rect x="26" y="112" width="28" height="20" rx="1.2"
                fill="none" stroke="#d4a76a" stroke-width="0.35" opacity="0.4" />
          <text x="40" y="125" text-anchor="middle"
                font-family="JetBrains Mono, monospace" font-size="4.2"
                letter-spacing="1.5" fill="#d4a76a" opacity="0.85">FIDELIS</text>
          <line x1="29" y1="129" x2="51" y2="129"
                stroke="#d4a76a" stroke-width="0.25" opacity="0.45" />

          <!-- Bottom seam -->
          <line x1="22" y1="160" x2="58" y2="160"
                stroke="#0a0505" stroke-width="0.5" opacity="0.7" />
          <!-- Bottom-right hinge pin -->
          <circle cx="56" cy="163" r="0.6" fill="#c8a068" opacity="0.65" />

          <!-- === Metal cap (windguard) === -->
          <rect x="22" y="52" width="36" height="22" rx="2"
                fill="url(#lighterCap)" />
          <!-- Cap highlight -->
          <rect x="24" y="53.5" width="32" height="1.2" rx="0.6"
                fill="#ffffff" opacity="0.45" />
          <!-- Cap slots (seven vertical) -->
          <g fill="#05050a" opacity="0.82">
            <rect x="26.5" y="56" width="1.4" height="6" rx="0.5" />
            <rect x="30"   y="56" width="1.4" height="6" rx="0.5" />
            <rect x="33.5" y="56" width="1.4" height="6" rx="0.5" />
            <rect x="37"   y="56" width="1.4" height="6" rx="0.5" />
            <rect x="40.5" y="56" width="1.4" height="6" rx="0.5" />
            <rect x="44"   y="56" width="1.4" height="6" rx="0.5" />
            <rect x="47.5" y="56" width="1.4" height="6" rx="0.5" />
            <rect x="51"   y="56" width="1.4" height="6" rx="0.5" />
          </g>
          <!-- Cap base shadow -->
          <rect x="22" y="72" width="36" height="1.5"
                fill="#000" opacity="0.45" />

          <!-- === Thumb wheel === -->
          <rect x="28" y="42" width="24" height="12" rx="1.5"
                fill="url(#wheelGrad)" stroke="#1a1a20" stroke-width="0.3" />
          <g stroke="#1c1c22" stroke-width="0.5" opacity="0.9">
            <line x1="30" y1="44" x2="30" y2="52" />
            <line x1="32.5" y1="44" x2="32.5" y2="52" />
            <line x1="35" y1="44" x2="35" y2="52" />
            <line x1="37.5" y1="44" x2="37.5" y2="52" />
            <line x1="40" y1="44" x2="40" y2="52" />
            <line x1="42.5" y1="44" x2="42.5" y2="52" />
            <line x1="45" y1="44" x2="45" y2="52" />
            <line x1="47.5" y1="44" x2="47.5" y2="52" />
            <line x1="50" y1="44" x2="50" y2="52" />
          </g>
          <!-- Wheel highlight -->
          <rect x="29" y="43" width="22" height="1"
                fill="#ffffff" opacity="0.35" />

          <!-- Small wick nub peeking from cap -->
          <rect x="38.5" y="50" width="3" height="4" rx="0.4"
                fill="#0a0404" opacity="0.85" />

          <!-- === Flame === -->
          <g class="flame">
            <!-- Outer plume (with dance) -->
            <g class="flame-plume">
              <!-- Broad halo -->
              <ellipse cx="40" cy="22" rx="14" ry="34" fill="url(#flameOuter)" opacity="0.85" />
              <!-- Teardrop main body -->
              <path d="M40,-4
                       C47,6  52,18  50,32
                       C49,42 45,48  40,52
                       C35,48 31,42  30,32
                       C28,18 33,6   40,-4 Z"
                    fill="url(#flameOuter)" />
              <!-- Mid flame -->
              <g class="flame-core">
                <path d="M40,6
                         C45,14 48,22  46,32
                         C45,40 43,45  40,48
                         C37,45 35,40  34,32
                         C32,22 35,14  40,6 Z"
                      fill="url(#flameMid)" />
                <!-- Innermost white hot core -->
                <ellipse cx="40" cy="30" rx="3" ry="10" fill="url(#flameCore)" />
              </g>
            </g>
            <!-- Blue base (independent flicker) -->
            <g class="flame-base">
              <ellipse cx="40" cy="48" rx="5" ry="7" fill="url(#flameBlue)" />
            </g>
          </g>
        </svg>
      </div>

      <!-- Embers (rise from the paper burn point, top of lighter flame) -->
      <div class="ember-stage">
        <div class="ember"         style="bottom: 50%; right: 30%; --ex: -28px; --ey: -260px"></div>
        <div class="ember ember-2" style="bottom: 52%; right: 32%; --ex: -12px; --ey: -320px"></div>
        <div class="ember ember-3" style="bottom: 48%; right: 28%; --ex: -46px; --ey: -240px"></div>
        <div class="ember ember-4" style="bottom: 54%; right: 34%; --ex: -22px; --ey: -360px"></div>
        <div class="ember ember-5" style="bottom: 49%; right: 31%; --ex: -38px; --ey: -300px"></div>
        <div class="ember ember-6" style="bottom: 51%; right: 29%; --ex: -18px; --ey: -220px"></div>
        <div class="ember ember-7" style="bottom: 53%; right: 33%; --ex: -52px; --ey: -340px"></div>
        <div class="ember ember-8" style="bottom: 50%; right: 27%; --ex: -32px; --ey: -280px"></div>
      </div>

      <!-- Ash flakes falling from the burn edge -->
      <div class="ash-stage">
        <span class="ash" style="bottom: 48%; right: 26%; --ax: -40px; --ay: 200px; --ar: 220deg; --ad: 6s;   --delay: 0s"></span>
        <span class="ash" style="bottom: 46%; right: 28%; --ax: -55px; --ay: 260px; --ar: -180deg; --ad: 7.2s; --delay: 1.1s"></span>
        <span class="ash" style="bottom: 49%; right: 24%; --ax: -30px; --ay: 180px; --ar: 140deg;  --ad: 5.4s; --delay: 2.3s"></span>
        <span class="ash" style="bottom: 47%; right: 30%; --ax: -70px; --ay: 300px; --ar: -260deg; --ad: 8.2s; --delay: 0.6s"></span>
        <span class="ash" style="bottom: 48%; right: 25%; --ax: -22px; --ay: 240px; --ar: 90deg;   --ad: 6.6s; --delay: 3.4s"></span>
        <span class="ash" style="bottom: 46%; right: 27%; --ax: -48px; --ay: 220px; --ar: -120deg; --ad: 5.8s; --delay: 1.8s"></span>
        <span class="ash" style="bottom: 49%; right: 23%; --ax: -60px; --ay: 280px; --ar: 200deg;  --ad: 7.6s; --delay: 2.8s"></span>
      </div>

      <!-- Smoke plumes (two layers for depth) -->
      <div class="smoke-2"></div>
      <div class="smoke"></div>

     </div>
    </div>

    <!-- Minimal floating top bar -->
    <header class="landing-header fixed inset-x-0 top-0 z-40">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-8 px-6 py-4 text-xs">
        <a href="/" class="group flex items-center gap-2.5 text-ink-100" aria-label="Fidelis home">
          <span class="grid h-6 w-6 place-items-center rounded-full bg-gradient-to-br from-brand-400 to-accent-500 text-ink-950 text-[10px] font-bold">
            F
          </span>
          <span class="font-mono tracking-[0.22em] text-[11px] transition group-hover:text-white">
            FIDELIS
          </span>
        </a>
        <nav class="flex items-center gap-6 font-mono text-[10.5px] tracking-[0.22em] text-ink-400">
          <a href="/agent" class="transition hover:text-white">/agent</a>
