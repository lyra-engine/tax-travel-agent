    <!-- ============================================================== -->
    <!-- Scroll logic                                                      -->
    <!-- ============================================================== -->
    <script is:inline>
      (function () {
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const root = document.documentElement;

        /* -------------------------------------------------------------- */
        /* 1 · Split text: wrap each character in a span.ch with --i index */
        /* -------------------------------------------------------------- */
        function splitText(el) {
          if (el.dataset.splitDone === "1") return;
          el.setAttribute("aria-label", el.textContent.trim());
          const variant = el.dataset.split;
          el.classList.add("split-chars");
          if (variant === "subtle") el.classList.add("subtle");

          let counter = 0;
          const walk = (node) => {
            const kids = Array.from(node.childNodes);
            for (const k of kids) {
              if (k.nodeType === Node.TEXT_NODE) {
                const text = k.textContent || "";
                const frag = document.createDocumentFragment();
                for (const token of text.split(/(\s+)/)) {
                  if (token === "") continue;
                  if (/^\s+$/.test(token)) {
                    frag.appendChild(document.createTextNode(token));
                    continue;
                  }
                  const word = document.createElement("span");
                  word.className = "word";
                  word.setAttribute("aria-hidden", "true");
                  for (const c of Array.from(token)) {
                    const s = document.createElement("span");
                    s.className = "ch";
                    s.style.setProperty("--i", String(counter++));
                    s.textContent = c;
                    word.appendChild(s);
                  }
                  frag.appendChild(word);
                }
                k.parentNode.replaceChild(frag, k);
              } else if (k.nodeType === Node.ELEMENT_NODE) {
                if (k.tagName === "BR") continue;
                walk(k);
              }
            }
          };
          walk(el);
          el.dataset.splitDone = "1";
        }

        if (!reduce) {
          document.querySelectorAll("[data-split]").forEach(splitText);
        }

        /* -------------------------------------------------------------- */
        /* 1b · Montana-style splitters (letters: slam/rise, words: slide) */
        /* For any element with [data-slam], [data-rise], or [data-slide] */
        /* -------------------------------------------------------------- */
        function splitLetters(el, cls, baseDelay, step) {
          if (el.dataset.animDone === "1") return;
          const text = el.textContent || "";
          el.setAttribute("aria-label", text.trim());
          el.textContent = "";
          let i = 0;
          for (const ch of Array.from(text)) {
            if (ch === " ") {
              el.appendChild(document.createTextNode(" "));
              continue;
            }
            const span = document.createElement("span");
            span.className = cls;
            span.setAttribute("aria-hidden", "true");
            span.style.animationDelay = `${baseDelay + i * step}ms`;
            span.textContent = ch;
            el.appendChild(span);
            i++;
          }
          el.dataset.animDone = "1";
        }
        function splitWordsAnim(el, cls, baseDelay, step) {
          if (el.dataset.animDone === "1") return;
          const text = el.textContent || "";
          el.setAttribute("aria-label", text.trim());
          el.textContent = "";
          const words = text.split(/(\s+)/).filter((w) => w !== "");
          let i = 0;
          for (const w of words) {
            if (/^\s+$/.test(w)) {
              el.appendChild(document.createTextNode(w));
              continue;
            }
            const span = document.createElement("span");
            span.className = cls;
            span.setAttribute("aria-hidden", "true");
            span.style.animationDelay = `${baseDelay + i * step}ms`;
            span.textContent = w;
            el.appendChild(span);
            i++;
          }
          el.dataset.animDone = "1";
        }

        if (!reduce) {
          document.querySelectorAll("[data-slam]").forEach((el) => {
            const base = parseInt(el.dataset.slamDelay || "0", 10);
            const step = parseInt(el.dataset.slamStep || "75", 10);
            splitLetters(el, "anim-slam", base, step);
          });
          document.querySelectorAll("[data-rise]").forEach((el) => {
            const base = parseInt(el.dataset.riseDelay || "0", 10);
            const step = parseInt(el.dataset.riseStep || "28", 10);
            splitLetters(el, "anim-letter", base, step);
          });
          document.querySelectorAll("[data-slide]").forEach((el) => {
            const base = parseInt(el.dataset.slideDelay || "0", 10);
            const step = parseInt(el.dataset.slideStep || "90", 10);
            splitWordsAnim(el, "anim-word", base, step);
          });
        }

        /* -------------------------------------------------------------- */
        /* 2 · Reveal on enter (splits + .reveal + Montana .anim-* hosts)  */
        /* -------------------------------------------------------------- */
        const revealTargets = document.querySelectorAll(
          ".reveal, [data-split], [data-reveal-host], [data-slam], [data-rise], [data-slide]",
        );
        if (!reduce && "IntersectionObserver" in window) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add("is-in");
                  /* Montana-style trigger: child .anim-* elements wait
                     for [data-revealed] on their host. */
                  e.target.setAttribute("data-revealed", "");
                  io.unobserve(e.target);
                }
              }
            },
            { threshold: 0.12, rootMargin: "0px 0px -6% 0px" },
          );
          revealTargets.forEach((el) => io.observe(el));
        } else {
          revealTargets.forEach((el) => {
            el.classList.add("is-in");
            el.setAttribute("data-revealed", "");
          });
        }

        /* -------------------------------------------------------------- */
        /* 3 · Scroll loop: --sy, --sp, per-element --p, HUD, progress     */
        /* -------------------------------------------------------------- */
        const bar = document.getElementById("progress-bar");
        const hudPct = document.getElementById("hud-pct");
        const hudCh = document.getElementById("hud-ch");
        const parallaxEls = Array.from(document.querySelectorAll("[data-parallax]"));

        // Chapter ids for keyboard nav and HUD
        const ids = ["ch-00", "ch-01", "ch-02", "ch-03", "ch-04", "ch-05"];
        const chapters = ids.map((id) => document.getElementById(id));

        // Right-edge nav dots
        const navLinks = Array.from(document.querySelectorAll("#chapter-nav a"));
        const activateNav = (i) => {
          navLinks.forEach((a, idx) => {
            const on = idx === i;
            a.classList.toggle("is-active", on);
            if (on) a.setAttribute("aria-current", "location");
            else a.removeAttribute("aria-current");
          });
        };

        let scheduled = false;
        const tick = () => {
          scheduled = false;
          const y = window.scrollY;
          const h = root.scrollHeight - root.clientHeight;
          const sp = y / Math.max(1, h);
          root.style.setProperty("--sy", y + "px");
          root.style.setProperty("--sp", sp.toFixed(4));

          if (bar) bar.style.width = Math.min(100, sp * 100) + "%";
          if (hudPct) hudPct.textContent = String(Math.round(sp * 100)).padStart(2, "0");

          const vh = window.innerHeight;
          // Per-element progress (-1 above, 0 center, 1 below)
          for (const el of parallaxEls) {
            const r = el.getBoundingClientRect();
            const center = r.top + r.height / 2;
            const p = (center - vh / 2) / (vh / 2 + r.height / 2);
            el.style.setProperty("--p", Math.max(-1, Math.min(1, p)).toFixed(3));
          }

          // Find active chapter by which one covers viewport center
          const midY = window.scrollY + vh / 2;
          let active = 0;
          for (let i = 0; i < chapters.length; i++) {
            const c = chapters[i];
            if (!c) continue;
            if (midY >= c.offsetTop) active = i;
          }
          if (hudCh) hudCh.textContent = String(active).padStart(2, "0");
          activateNav(active);
          chapters.forEach((c, i) => {
            if (!c) return;
            c.classList.toggle("landing-chapter-active", i === active);
          });
        };

        const onScroll = () => {
          if (scheduled) return;
          scheduled = true;
          requestAnimationFrame(tick);
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", onScroll, { passive: true });
        tick();

        /* -------------------------------------------------------------- */
        /* 4 · Keyboard nav                                                */
        /* -------------------------------------------------------------- */
        const currentChapter = () => {
          const y = window.scrollY + window.innerHeight / 2;
          let best = 0;
          ids.forEach((id, i) => {
            const el = document.getElementById(id);
            if (!el) return;
            if (y >= el.offsetTop) best = i;
          });
          return best;
        };
        window.addEventListener("keydown", (e) => {
          const tag = e.target && e.target.tagName;
          if (tag && ["INPUT", "TEXTAREA", "SELECT"].includes(tag)) return;
          if (e.key === "ArrowDown" || e.key === "PageDown") {
            e.preventDefault();
            const i = Math.min(ids.length - 1, currentChapter() + 1);
            document.getElementById(ids[i])?.scrollIntoView({ behavior: "smooth" });
          } else if (e.key === "ArrowUp" || e.key === "PageUp") {
            e.preventDefault();
            const i = Math.max(0, currentChapter() - 1);
            document.getElementById(ids[i])?.scrollIntoView({ behavior: "smooth" });
          } else if (e.key === "/") {
            e.preventDefault();
            window.location.href = "/agent";
          }
        });
      })();
    </script>
	</body>
</html>

