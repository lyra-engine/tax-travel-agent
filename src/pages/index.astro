          advisor flow. Add an OpenAI key and ship.
        </p>

        <div class="reveal reveal-delay-2 mt-12 flex flex-wrap items-center gap-4">
          <a
            href="/agent"
            class="group inline-flex items-center gap-3 rounded-full bg-white px-7 py-4 text-sm font-medium text-ink-950 transition hover:bg-ink-100"
          >
            Launch the agent
            <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
          </a>
          <a
            href="/scenarios"
            class="inline-flex items-center gap-3 rounded-full border border-white/15 px-7 py-4 text-sm text-ink-200 transition hover:border-white/30 hover:text-white"
          >
            Compare two scenarios
          </a>
          <a
            href="/intake"
            class="inline-flex items-center gap-3 rounded-full border border-white/15 px-7 py-4 text-sm text-ink-200 transition hover:border-white/30 hover:text-white"
          >
            Upload a 1099
          </a>
        </div>

        <div class="reveal reveal-delay-3 mt-20 grid gap-6 border-t border-white/5 pt-10 font-mono text-[11px] text-ink-500 sm:grid-cols-3">
          <div>
            <p class="text-ink-300">Not tax or legal advice.</p>
            <p class="mt-1 max-w-sm leading-relaxed text-ink-500">
              Fidelis is an educational/analytical tool under advisor
              supervision. Verify against current IRS and state guidance before
              acting.
            </p>
          </div>
          <div>
            <p class="text-ink-300">Stack</p>
            <p class="mt-1 text-ink-500">Astro · React · OpenAI · TypeScript · SQLite</p>
          </div>
          <div class="sm:text-right">
            <p class="text-ink-300">Fidelis</p>
            <p class="mt-1 text-ink-500">A base tax agent for financial advisors.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================== -->
    <!-- Scroll logic                                                      -->
    <!-- ============================================================== -->
    <script is:inline>
      (function () {
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const root = document.documentElement;

        /* -------------------------------------------------------------- */
        /* 1 · Split text: wrap each character in a span.ch with --i index */
        /* -------------------------------------------------------------- */
        function splitText(el) {
          if (el.dataset.splitDone === "1") return;
          el.setAttribute("aria-label", el.textContent.trim());
          const variant = el.dataset.split;
          el.classList.add("split-chars");
          if (variant === "subtle") el.classList.add("subtle");

          let counter = 0;
          const walk = (node) => {
            const kids = Array.from(node.childNodes);
            for (const k of kids) {
              if (k.nodeType === Node.TEXT_NODE) {
                const text = k.textContent || "";
                const frag = document.createDocumentFragment();
                for (const token of text.split(/(\s+)/)) {
                  if (token === "") continue;
                  if (/^\s+$/.test(token)) {
                    frag.appendChild(document.createTextNode(token));
                    continue;
                  }
                  const word = document.createElement("span");
                  word.className = "word";
                  word.setAttribute("aria-hidden", "true");
                  for (const c of Array.from(token)) {
                    const s = document.createElement("span");
                    s.className = "ch";
                    s.style.setProperty("--i", String(counter++));
                    s.textContent = c;
                    word.appendChild(s);
                  }
                  frag.appendChild(word);
                }
                k.parentNode.replaceChild(frag, k);
              } else if (k.nodeType === Node.ELEMENT_NODE) {
                if (k.tagName === "BR") continue;
                walk(k);
              }
            }
          };
          walk(el);
          el.dataset.splitDone = "1";
        }

        if (!reduce) {
          document.querySelectorAll("[data-split]").forEach(splitText);
        }

        /* -------------------------------------------------------------- */
        /* 2 · Reveal on enter (splits + .reveal elements)                 */
        /* -------------------------------------------------------------- */
        const revealTargets = document.querySelectorAll(".reveal, [data-split]");
        if (!reduce && "IntersectionObserver" in window) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add("is-in");
                  io.unobserve(e.target);
                }
              }
            },
            { threshold: 0.12, rootMargin: "0px 0px -6% 0px" },
          );
          revealTargets.forEach((el) => io.observe(el));
        } else {
          revealTargets.forEach((el) => el.classList.add("is-in"));
        }

        /* -------------------------------------------------------------- */
        /* 3 · Scroll loop: --sy, --sp, per-element --p, HUD, progress     */
        /* -------------------------------------------------------------- */
        const bar = document.getElementById("progress-bar");
        const hudPct = document.getElementById("hud-pct");
        const hudCh = document.getElementById("hud-ch");
        const parallaxEls = Array.from(document.querySelectorAll("[data-parallax]"));

        // Chapter ids for keyboard nav and HUD
        const ids = ["ch-00", "ch-01", "ch-02", "ch-03", "ch-04", "ch-05"];
        const chapters = ids.map((id) => document.getElementById(id));

        // Right-edge nav dots
        const navLinks = Array.from(document.querySelectorAll("#chapter-nav a"));
        const activateNav = (i) => {
          navLinks.forEach((a, idx) => {
            const line = a.querySelector("span:last-child");
            const label = a.querySelector("span:first-child");
            if (!line || !label) return;
            line.style.width = idx === i ? "2rem" : "1rem";
            label.style.color = idx === i ? "white" : "";
          });
        };

        let scheduled = false;
        const tick = () => {
          scheduled = false;
          const y = window.scrollY;
          const h = root.scrollHeight - root.clientHeight;
          const sp = y / Math.max(1, h);
          root.style.setProperty("--sy", y + "px");
          root.style.setProperty("--sp", sp.toFixed(4));

          if (bar) bar.style.width = Math.min(100, sp * 100) + "%";
          if (hudPct) hudPct.textContent = String(Math.round(sp * 100)).padStart(2, "0");

          const vh = window.innerHeight;
          // Per-element progress (-1 above, 0 center, 1 below)
          for (const el of parallaxEls) {
            const r = el.getBoundingClientRect();
            const center = r.top + r.height / 2;
            const p = (center - vh / 2) / (vh / 2 + r.height / 2);
            el.style.setProperty("--p", Math.max(-1, Math.min(1, p)).toFixed(3));
          }

          // Find active chapter by which one covers viewport center
          const midY = window.scrollY + vh / 2;
          let active = 0;
          for (let i = 0; i < chapters.length; i++) {
            const c = chapters[i];
            if (!c) continue;
            if (midY >= c.offsetTop) active = i;
          }
          if (hudCh) hudCh.textContent = String(active).padStart(2, "0");
          activateNav(active);
        };

        const onScroll = () => {
          if (scheduled) return;
          scheduled = true;
          requestAnimationFrame(tick);
        };
        if (!reduce) {
          window.addEventListener("scroll", onScroll, { passive: true });
          window.addEventListener("resize", onScroll, { passive: true });
        }
        tick();

        /* -------------------------------------------------------------- */
        /* 4 · Keyboard nav                                                */
        /* -------------------------------------------------------------- */
        const currentChapter = () => {
          const y = window.scrollY + window.innerHeight / 2;
          let best = 0;
          ids.forEach((id, i) => {
            const el = document.getElementById(id);
            if (!el) return;
            if (y >= el.offsetTop) best = i;
          });
          return best;
        };
        window.addEventListener("keydown", (e) => {
          const tag = e.target && e.target.tagName;
          if (tag && ["INPUT", "TEXTAREA", "SELECT"].includes(tag)) return;
          if (e.key === "ArrowDown" || e.key === "PageDown") {
            e.preventDefault();
            const i = Math.min(ids.length - 1, currentChapter() + 1);
            document.getElementById(ids[i])?.scrollIntoView({ behavior: "smooth" });
          } else if (e.key === "ArrowUp" || e.key === "PageUp") {
            e.preventDefault();
            const i = Math.max(0, currentChapter() - 1);
            document.getElementById(ids[i])?.scrollIntoView({ behavior: "smooth" });
          } else if (e.key === "/") {
            e.preventDefault();
            window.location.href = "/agent";
          }
        });
      })();
    </script>
  </body>
</html>

