---
import Layout from "../layouts/Layout.astro";
import { authEnabled, listOrgMembers } from "../lib/auth/auth";

export const prerender = false;

const user = Astro.locals.user;
const org = Astro.locals.org;
const enabled = authEnabled();

if (enabled && !user) {
  return Astro.redirect("/login?next=/team");
}
if (enabled && user?.role !== "admin") {
  return Astro.redirect("/agent");
}

const members = org ? listOrgMembers(org.id) : [];
---

<Layout title={`Team — ${org?.name ?? "Fidelis"}`}>
  <section class="mx-auto max-w-5xl px-6 pt-10 pb-20">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <span class="chip w-fit">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
          Admin
        </span>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Team
        </h1>
        <p class="mt-2 max-w-2xl text-ink-300">
          Members of <b class="text-ink-100">{org?.name ?? "your firm"}</b>.
          Invite advisors and staff below. Everyone in your org shares the same
          audit log and agent environment.
        </p>
      </div>
    </div>

    {!enabled && (
      <div class="mt-6 rounded-xl border border-warn-500/40 bg-warn-500/10 px-4 py-3 text-sm text-warn-200">
        <p class="font-medium text-warn-300">Auth is disabled</p>
        <p class="mt-1 text-xs text-warn-200/80">
          Set <code class="rounded bg-black/30 px-1 font-mono">FIDELIS_AUTH=1</code>
          and restart the server to enforce login and actually use the invite
          system.
        </p>
      </div>
    )}

    <div class="mt-8 grid gap-6 lg:grid-cols-[2fr,1fr]">
      <div class="card overflow-hidden p-0">
        <div class="border-b border-white/5 px-4 py-2 text-xs uppercase tracking-wider text-ink-500">
          Members ({members.length})
        </div>
        {members.length === 0 ? (
          <div class="px-4 py-10 text-center text-sm text-ink-400">
            No members yet. Invite someone →
          </div>
        ) : (
          <table class="w-full text-sm">
            <thead class="border-b border-white/5 text-left text-[10px] uppercase tracking-wider text-ink-500">
              <tr>
                <th class="px-4 py-2 font-medium">Name</th>
                <th class="px-4 py-2 font-medium">Email</th>
                <th class="px-4 py-2 font-medium">Role</th>
                <th class="px-4 py-2 font-medium">Joined</th>
              </tr>
            </thead>
            <tbody>
              {members.map((m) => (
                <tr class="border-t border-white/5">
                  <td class="px-4 py-2 text-ink-100">{m.name}</td>
                  <td class="px-4 py-2 text-ink-300">{m.email}</td>
                  <td class="px-4 py-2">
                    <span
                      class={`rounded-full px-2 py-0.5 text-[10px] uppercase tracking-wider ${
                        m.role === "admin"
                          ? "bg-brand-500/15 text-brand-300"
                          : "bg-white/5 text-ink-300"
                      }`}
                    >
                      {m.role}
                    </span>
                  </td>
                  <td class="px-4 py-2 text-xs text-ink-400">
                    {new Date(m.createdAt).toLocaleDateString()}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>

      <div class="card p-5">
        <h2 class="text-sm font-semibold text-white">Invite a member</h2>
        <p class="mt-1 text-xs text-ink-400">
          We'll generate a signup link you can send directly (or copy into your
          own email template).
        </p>
        <form
          id="invite-form"
          method="post"
          action="/api/auth/invite"
          class="mt-4 space-y-3"
        >
          <label class="block">
            <span class="text-[11px] uppercase tracking-wider text-ink-400">Email</span>
            <input
              name="email"
              type="email"
              required
              class="mt-1 w-full rounded-lg border border-white/10 bg-ink-900/60 px-3 py-2 text-sm text-white outline-none focus:border-brand-500"
            />
          </label>
          <label class="block">
            <span class="text-[11px] uppercase tracking-wider text-ink-400">Role</span>
            <select
              name="role"
              class="mt-1 w-full rounded-lg border border-white/10 bg-ink-900/60 px-3 py-2 text-sm text-white outline-none focus:border-brand-500"
            >
              <option value="member">Member</option>
              <option value="admin">Admin</option>
            </select>
          </label>
          <button class="w-full rounded-lg bg-brand-500 px-3 py-2 text-sm font-medium text-white hover:bg-brand-400">
            Generate invite link
          </button>
        </form>
        <div
          id="invite-result"
          class="mt-4 hidden rounded-lg border border-accent-500/30 bg-accent-500/5 p-3 text-xs text-ink-200"
        ></div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("invite-form") as HTMLFormElement | null;
  const out = document.getElementById("invite-result");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!out) return;
    const fd = new FormData(form);
    const res = await fetch("/api/auth/invite", {
      method: "POST",
      headers: { Accept: "application/json" },
      body: fd,
    });
    const j = await res.json();
    out.classList.remove("hidden");
    if (!j.ok) {
      out.textContent = j.error ?? "Failed to create invite.";
      return;
    }
    out.innerHTML = `
      <p class="font-medium text-accent-300">Invite link ready</p>
      <input readonly value="${j.link}"
        class="mt-2 w-full rounded border border-white/10 bg-black/30 px-2 py-1 font-mono text-[11px] text-ink-100" />
      <p class="mt-2 text-ink-400">Send this to ${escapeHtml(fd.get("email") as string)}. Expires in 7 days.</p>
    `;
    const el = out.querySelector("input") as HTMLInputElement | null;
    el?.select();
  });
  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    })[c]!);
  }
</script>
